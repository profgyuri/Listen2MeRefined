<UserControl x:Class="Listen2MeRefined.WPF.Views.MainWindow.TrackInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <Style x:Key="InfoBadgeText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#B5B5B5" />
        </Style>

        <Style x:Key="MetricCardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3D3D3D" />
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="Margin" Value="0,0,7,0" />
        </Style>

        <Style x:Key="MetricLabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#9F9F9F" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Border Margin="0,0,10,0"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="#3A3A3A"
            Background="#272727"
            Padding="8">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#232323"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,7">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <materialDesign:PackIcon Kind="Equalizer"
                                                 Width="14"
                                                 Height="14"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Foreground="{StaticResource TertiaryBrush}" />
                        <TextBlock Style="{StaticResource InfoBadgeText}" Text="NOW PLAYING" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border DockPanel.Dock="Right"
                            CornerRadius="8"
                            HorizontalAlignment="Right"
                            Background="{StaticResource TertiaryDarkBrush}"
                            BorderBrush="{StaticResource TertiaryLightMidBrush}"
                            BorderThickness="1"
                            Padding="7,2,7,2">
                        <TextBlock FontSize="10"
                                   Foreground="{StaticResource TertiaryLightBrush}"
                                   Text="LIVE" />
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="#232323"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource SecondaryBrush}"
                               Text="{Binding Song.Title, FallbackValue=Title}"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <materialDesign:PackIcon Kind="AccountMusic"
                                                 VerticalAlignment="Center"
                                                 Width="15"
                                                 Height="15"
                                                 Margin="0,0,6,0"
                                                 Foreground="#A3A3A3" />
                        <TextBlock FontSize="17"
                                   Foreground="#CCCCCC"
                                   Text="{Binding Song.Artist, FallbackValue=Artist}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="4" Columns="3">
                <Border Style="{StaticResource MetricCardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Metronome"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,5,0"
                                                     Foreground="{StaticResource TertiaryBrush}" />
                            <TextBlock Style="{StaticResource MetricLabelText}" Text="TEMPO" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource MetricValueText}"
                                   Margin="0,4,0,0"
                                   Text="{Binding Song.BPM, StringFormat={}{0} BPM, FallbackValue=0 BPM}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShapeOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,5,0"
                                                     Foreground="{StaticResource TertiaryBrush}" />
                            <TextBlock Style="{StaticResource MetricLabelText}" Text="GENRE" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource MetricValueText}"
                                   Margin="0,4,0,0"
                                   Text="{Binding Song.Genre, FallbackValue=Genre}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricCardBorder}" Margin="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="SignalCellular3"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,5,0"
                                                     Foreground="{StaticResource TertiaryBrush}" />
                            <TextBlock Style="{StaticResource MetricLabelText}" Text="BITRATE" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource MetricValueText}"
                                   Margin="0,4,0,0"
                                   Text="{Binding Song.Bitrate, StringFormat={}{0} Kbps, FallbackValue=1411 Kbps}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
