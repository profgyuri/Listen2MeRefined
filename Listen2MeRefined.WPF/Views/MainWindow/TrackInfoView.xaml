<UserControl x:Class="Listen2MeRefined.WPF.Views.MainWindow.TrackInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TrackInfoBackgroundBrush" Color="#2A2A2A" />
        <SolidColorBrush x:Key="TrackInfoAccentBrush" Color="{StaticResource TertiaryColor}" />

        <Style x:Key="MetricCardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="Background" Value="#2B2B2B" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="MetricLabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#A7A7A7" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MetricValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource TertiaryLightBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Border Margin="0,0,10,0"
            CornerRadius="10"
            BorderThickness="1"
            BorderBrush="{StaticResource DarkBorderBrush}"
            Background="{StaticResource TrackInfoBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="4" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    CornerRadius="10,10,0,0"
                    Background="{StaticResource TrackInfoAccentBrush}" />

            <Grid Grid.Row="1" Margin="14,12,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border HorizontalAlignment="Left"
                        Padding="10,3"
                        CornerRadius="14"
                        Background="#2A2A2A"
                        BorderBrush="{StaticResource TertiaryLightMidBrush}"
                        BorderThickness="1">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TertiaryLightBrush}"
                               Text="NOW PLAYING" />
                </Border>

                <StackPanel Grid.Row="1" Margin="0,10,0,8" VerticalAlignment="Center">
                    <TextBlock FontSize="27"
                               FontWeight="Bold"
                               Foreground="{StaticResource SecondaryBrush}"
                               Text="{Binding Song.Title, FallbackValue=Title}"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <materialDesign:PackIcon Kind="AccountMusic"
                                                 Width="16"
                                                 Height="16"
                                                 Margin="0,0,6,0"
                                                 Foreground="#A7A7A7" />
                        <TextBlock FontSize="18"
                                   FontStyle="Italic"
                                   Foreground="#CFCFCF"
                                   Text="{Binding Song.Artist, FallbackValue=Artist}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <UniformGrid Grid.Row="2" Columns="3">
                    <Border Style="{StaticResource MetricCardBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Metronome"
                                                         Width="14"
                                                         Height="14"
                                                         Margin="0,0,5,0"
                                                         Foreground="{StaticResource TertiaryBrush}" />
                                <TextBlock Style="{StaticResource MetricLabelText}" Text="TEMPO" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource MetricValueText}"
                                       Margin="0,4,0,0"
                                       Text="{Binding Song.BPM, StringFormat={}{0} BPM, FallbackValue=0 BPM}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardBorder}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ShapeOutline"
                                                         Width="14"
                                                         Height="14"
                                                         Margin="0,0,5,0"
                                                         Foreground="{StaticResource TertiaryBrush}" />
                                <TextBlock Style="{StaticResource MetricLabelText}" Text="GENRE" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource MetricValueText}"
                                       Margin="0,4,0,0"
                                       Text="{Binding Song.Genre, FallbackValue=Genre}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource MetricCardBorder}" Margin="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="SignalCellular3"
                                                         Width="14"
                                                         Height="14"
                                                         Margin="0,0,5,0"
                                                         Foreground="{StaticResource TertiaryBrush}" />
                                <TextBlock Style="{StaticResource MetricLabelText}" Text="BITRATE" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource MetricValueText}"
                                       Margin="0,4,0,0"
                                       Text="{Binding Song.Bitrate, StringFormat={}{0} Kbps, FallbackValue=1411 Kbps}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
