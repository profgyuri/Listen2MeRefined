<UserControl x:Class="Listen2MeRefined.WPF.Views.MainWindow.SearchResultsPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:utils="clr-namespace:Listen2MeRefined.WPF.Utils">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BorderAccentBrush" Color="{StaticResource TertiaryColor}" />
        <Style x:Key="ToolbarLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8A8A8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolbarValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="QuickActionButton" TargetType="Button" BasedOn="{StaticResource InteractionButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
            <Setter Property="Background" Value="#2E2E2E" />
            <Setter Property="Foreground" Value="{StaticResource TertiaryBrush}" />
        </Style>

        <Style x:Key="SearchResultsListView" TargetType="ListView" BasedOn="{StaticResource VirtualizedListView}">
            <Setter Property="Background" Value="#232323" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="SearchResultsListItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="BorderBrush" Value="#3B3B3B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="8,6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#313131" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource TertiaryDarkBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowExpandToggleButton" TargetType="ToggleButton">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#363636" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource TertiaryDarkBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Margin="0,8,0,0"
            Background="#272727"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="12"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition x:Name="ListRow" Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#222222"
                    BorderBrush="#393939"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="24" Height="24" Background="{StaticResource BorderAccentBrush}" CornerRadius="12" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="MusicNote" Width="14" Height="14" Foreground="#1F1F1F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    
                    <TextBlock Grid.Column="1" Style="{StaticResource ToolbarValueText}" Text="Search Results" Margin="10,0,0,0" />
                    <Button Grid.Column="2"
                            HorizontalAlignment="Right"
                            Style="{StaticResource QuickActionButton}"
                            Command="{Binding SendSelectedToPlaylistCommand}"
                            ToolTip="Add Selected / All to Playlist"
                            Content="{materialDesign:PackIcon Kind=ArrowRightCircleOutline, Size=20}" />
                </Grid>
            </Border>

            <ListView Grid.Row="2"
                      Height="{Binding ElementName=ListRow, Path=Height}"
                      Foreground="{StaticResource SecondaryBrush}"
                      dd:DragDrop.IsDragSource="True"
                      dd:DragDrop.IsDropTarget="True"
                      ItemsSource="{Binding SearchResults}"
                      SelectionMode="Extended"
                      ItemContainerStyle="{StaticResource SearchResultsListItem}"
                      Style="{StaticResource SearchResultsListView}"
                      utils:SelectionChangedCommandBehavior.AddedItemsCommand="{Binding SearchResultsSelectionAddedCommand}"
                      utils:SelectionChangedCommandBehavior.RemovedItemsCommand="{Binding SearchResultsSelectionRemovedCommand}">
                <ListView.InputBindings>
                    <KeyBinding Modifiers="Ctrl" Key="Right" Command="{Binding SendSelectedToPlaylistCommand}"/>
                </ListView.InputBindings>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ToggleButton x:Name="RowExpandToggle"
                                              Style="{StaticResource RowExpandToggleButton}"
                                              ToolTip="Show details">
                                    <Grid>
                                        <materialDesign:PackIcon x:Name="RowExpandIconDown"
                                                                 Kind="ChevronDown"
                                                                 Width="16"
                                                                 Height="16"
                                                                 Foreground="{StaticResource SecondaryBrush}" />
                                        <materialDesign:PackIcon x:Name="RowExpandIconUp"
                                                                 Kind="ChevronUp"
                                                                 Width="16"
                                                                 Height="16"
                                                                 Foreground="{StaticResource SecondaryBrush}"
                                                                 Visibility="Collapsed" />
                                    </Grid>
                                </ToggleButton>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Display}"
                                           FontSize="14"
                                           Foreground="{StaticResource SecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <Border Grid.Row="1"
                                    Margin="32,8,0,2"
                                    Padding="10,8"
                                    Background="#292929"
                                    BorderBrush="#3D3D3D"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Visibility="{Binding IsChecked, ElementName=RowExpandToggle, Converter={StaticResource BoolToVisibilityConverter}}">
                                <UniformGrid Columns="3">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Artist" Style="{StaticResource ToolbarLabelText}" />
                                        <TextBlock Text="{Binding Artist}" Style="{StaticResource ToolbarValueText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Title" Style="{StaticResource ToolbarLabelText}" />
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource ToolbarValueText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Genre" Style="{StaticResource ToolbarLabelText}" />
                                        <TextBlock Text="{Binding Genre}" Style="{StaticResource ToolbarValueText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Margin="0,8,12,0">
                                        <TextBlock Text="BPM" Style="{StaticResource ToolbarLabelText}" />
                                        <TextBlock Text="{Binding BPM}" Style="{StaticResource ToolbarValueText}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,8,12,0">
                                        <TextBlock Text="Bitrate" Style="{StaticResource ToolbarLabelText}" />
                                        <TextBlock Text="{Binding Bitrate, StringFormat={}{0} kbps}" Style="{StaticResource ToolbarValueText}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,8,0,0">
                                        <TextBlock Text="Path" Style="{StaticResource ToolbarLabelText}" />
                                        <TextBlock Text="{Binding Path}" Style="{StaticResource ToolbarValueText}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </UniformGrid>
                            </Border>
                        </Grid>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="RowExpandToggle" Property="IsChecked" Value="True">
                                <Setter TargetName="RowExpandIconDown" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="RowExpandIconUp" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>
