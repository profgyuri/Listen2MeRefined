<UserControl x:Class="Listen2MeRefined.WPF.Views.MainWindow.SearchBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:utils="clr-namespace:Listen2MeRefined.WPF.Utils">
    <UserControl.Resources>
        <Style x:Key="SearchActionButton" TargetType="Button" BasedOn="{StaticResource InteractionButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="Background" Value="#313131" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="BtnBorder" Property="Background" Value="#383838" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#262626" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border utils:ViewModelInitialization.AutoInitialize="True"
            Margin="0,12,0,0"
            Padding="12,10"
            Background="#272727"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Background="#232323"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="Magnify"
                                             Width="18"
                                             Height="18"
                                             Margin="0,0,8,0"
                                             VerticalAlignment="Center"
                                             Foreground="#A6A6A6" />

                    <TextBox Grid.Column="1"
                             Height="36"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource SecondaryBrush}"
                             CaretBrush="{StaticResource TertiaryBrush}"
                             VerticalContentAlignment="Center"
                             materialDesign:HintAssist.Hint="Quick Search"
                             materialDesign:HintAssist.Foreground="#9A9A9A"
                             Text="{Binding SearchTerm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding QuickSearchCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>
                </Grid>
            </Border>

            <Button Grid.Column="1"
                    Command="{Binding QuickSearchCommand}"
                    Style="{StaticResource SearchActionButton}"
                    ToolTip="Quick Search"
                    Content="{materialDesign:PackIcon Kind=Search,Size=18}" />
            <Button Grid.Column="2"
                    Command="{Binding DataContext.OpenAdvancedSearchWindowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource SearchActionButton}"
                    ToolTip="Advanced Search"
                    Content="{materialDesign:PackIcon Kind=Tune,Size=18}" />
        </Grid>
    </Border>
</UserControl>
