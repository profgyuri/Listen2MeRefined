<UserControl x:Class="Listen2MeRefined.WPF.Views.MainWindow.TitleBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="TitleActionButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="BtnBorder" Property="Background" Value="#353535" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#242424" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleActionButton" TargetType="Button" BasedOn="{StaticResource TitleActionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#970000" />
                    <Setter Property="BorderBrush" Value="#970000" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6F0000" />
                    <Setter Property="BorderBrush" Value="#6F0000" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Padding="10,4"
            BorderBrush="#3A3A3A"
            BorderThickness="0,0,0,1"
            Background="#232323">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    WindowChrome.IsHitTestVisibleInChrome="False"
                    CornerRadius="9"
                    BorderThickness="1"
                    BorderBrush="#3F3F3F"
                    Background="#2B2B2B"
                    Height="30"
                    Padding="8,4"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Listen2Me.ico"
                           Width="16"
                           Height="16"
                           SnapsToDevicePixels="True"
                           Margin="0,0,7,0" />
                    <TextBlock Text="Listen2Me Refined"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    WindowChrome.IsHitTestVisibleInChrome="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Height="30"
                    Padding="10,4"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#3D3D3D"
                    Background="#292929">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6"
                             Height="6"
                             Fill="{StaticResource TertiaryBrush}"
                             Margin="0,0,6,0" />
                    <!-- This block below will be replaced with the status messages -->
                    <TextBlock Text="Desktop Player" 
                               FontSize="12"
                               Foreground="{StaticResource SecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Grid Margin="0,0,6,0">
                    <Button Command="{Binding OpenSettingsWindowCommand}"
                            Style="{StaticResource TitleActionButton}"
                            Content="{materialDesign:PackIcon Kind=CogOutline,Size=15}" />
                    <Border Width="11"
                            Height="11"
                            Background="#D14949"
                            CornerRadius="5.5"
                            BorderBrush="#F2A7A7"
                            BorderThickness="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-3,-2,0"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                            IsHitTestVisible="False" />
                </Grid>

                <Button Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=MinimizeWindowCommand}"
                        Style="{StaticResource TitleActionButton}"
                        Content="{materialDesign:PackIcon Kind=WindowMinimize,Size=15}" />
                <Button Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ToggleWindowStateCommand}"
                        Style="{StaticResource TitleActionButton}"
                        Content="{materialDesign:PackIcon Kind=WindowMaximize,Size=15}"
                        Margin="6,0,0,0" />
                <Button Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=CloseWindowCommand}"
                        Style="{StaticResource CloseTitleActionButton}"
                        Content="{materialDesign:PackIcon Kind=Close,Size=15}"
                        Margin="6,0,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
