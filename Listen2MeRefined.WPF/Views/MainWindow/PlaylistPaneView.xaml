<UserControl x:Class="Listen2MeRefined.WPF.Views.MainWindow.PlaylistPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:resources="clr-namespace:Listen2MeRefined.WPF"
             xmlns:utils="clr-namespace:Listen2MeRefined.WPF.Utils">
    <UserControl.Resources>
        <Style x:Key="PlaylistTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RemovePlaylistButton" TargetType="Button" BasedOn="{StaticResource InteractionButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
            <Setter Property="Background" Value="#2E2E2E" />
            <Setter Property="Foreground" Value="{StaticResource TertiaryBrush}" />
        </Style>

        <Style x:Key="PlaylistList" TargetType="ListView" BasedOn="{StaticResource VirtualizedListView}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="#242424" />
                        <Setter Property="BorderBrush" Value="#383838" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10"
                                            Padding="10,8">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2C2C2C" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#323232" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetaBadge" TargetType="Border">
            <Setter Property="Background" Value="#2E2E2E" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="MetaText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D7D7D7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </UserControl.Resources>

    <Border Margin="0,20,0,14"
            Background="#272727"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="12"
            Padding="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#222222"
                    BorderBrush="#393939"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Width="24" Height="24" Background="{StaticResource TertiaryBrush}" CornerRadius="12" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="PlaylistMusic" Width="14" Height="14" Foreground="#1F1F1F" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Column="1" Style="{StaticResource PlaylistTitleText}" Text="Playlist" Margin="10,0,0,0" />

                    <Button Grid.Column="2"
                            Style="{StaticResource RemovePlaylistButton}"
                            Content="{materialDesign:PackIcon Kind=CloseBoxOutline, Size=20}"
                            Command="{Binding RemoveSelectedFromPlaylistCommand}"
                            ToolTip="Remove Selected / All from Playlist" />
                </Grid>
            </Border>

            <ListView Grid.Row="2"
                      dd:DragDrop.IsDragSource="True"
                      dd:DragDrop.IsDropTarget="True"
                      ItemsSource="{Binding PlayList}"
                      Style="{StaticResource PlaylistList}"
                      SelectedIndex="{Binding SelectedIndex}"
                      SelectedItem="{Binding SelectedSong}"
                      utils:SelectionChangedCommandBehavior.AddedItemsCommand="{Binding PlaylistSelectionAddedCommand}"
                      utils:SelectionChangedCommandBehavior.RemovedItemsCommand="{Binding PlaylistSelectionRemovedCommand}"
                      utils:SelectionChangedCommandBehavior.ScrollSelectedItemIntoView="True">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding JumpToSelectedSongCommand}" />
                    </i:EventTrigger>
                    <i:EventTrigger EventName="MouseRightButtonUp">
                        <i:InvokeCommandAction Command="{Binding SwitchToSongMenuTabCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <ListView.InputBindings>
                    <KeyBinding Modifiers="Ctrl" Key="Delete" Command="{Binding RemoveSelectedFromPlaylistCommand}"/>
                    <KeyBinding Modifiers="Ctrl+Shift" Key="Delete" Command="{Binding RemoveSelectedFromPlaylistCommand}"/>
                </ListView.InputBindings>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinWidth="320" ClipToBounds="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <resources:StoryboardTextBlock Text="{Binding Display, FallbackValue=Track}"
                                                           Foreground="#D7D7D7"
                                                           FontSize="16"
                                                           FontWeight="Bold"
                                                           TextTrimming="None"
                                                           HorizontalAlignment="Left"
                                                           ClipToBounds="True"
                                                           utils:FlowingTextBehavior.IsEnabled="True" />

                            <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                                <Border Style="{StaticResource MetaBadge}">
                                    <TextBlock Style="{StaticResource MetaText}" Text="{Binding BPM, StringFormat={}{0} BPM, FallbackValue=BPM}" />
                                </Border>
                                <Border Style="{StaticResource MetaBadge}">
                                    <TextBlock Style="{StaticResource MetaText}" Text="{Binding Bitrate, StringFormat={}{0} Kbps, FallbackValue=Bitrate}" />
                                </Border>
                                <Border Style="{StaticResource MetaBadge}">
                                    <TextBlock Style="{StaticResource MetaText}" Text="{Binding Length, StringFormat={}{0:hh\\:mm\\:ss\\.f}, FallbackValue=Length}" />
                                </Border>
                                <Border Style="{StaticResource MetaBadge}" Margin="0">
                                    <TextBlock Style="{StaticResource MetaText}" Text="{Binding Genre, FallbackValue=Genre}" />
                                </Border>
                            </WrapPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>
