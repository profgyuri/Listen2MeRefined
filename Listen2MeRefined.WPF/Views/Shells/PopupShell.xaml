<Window x:Class="Listen2MeRefined.WPF.Views.Shells.PopupShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Listen2MeRefined.WPF.Views.Shells"
        xmlns:shells="clr-namespace:Listen2MeRefined.Application.ViewModels.Shells;assembly=Listen2MeRefined.Application"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance shells:PopupShellViewModel}"
        Title="PopupShell" Height="450" Width="800">
    
        <WindowChrome.WindowChrome>
                <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
        </WindowChrome.WindowChrome>
        
        <Border BorderThickness="2" BorderBrush="{DynamicResource TertiaryBrush}" Background="{DynamicResource PrimaryBrush}" CornerRadius="0, 0, 8, 8">
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                                <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <components:TitleBar CenterText="{Binding CurrentViewModel.DisplayTitle}"
                                             ShowSettingsButton="False"
                                             ShowMinimizeButton="False"
                                             ShowMaximizeButton="False"
                                             ShowCloseButton="False"
                                             IsUpdateAvailableFeedbackVisible="False"/>

                        <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}"/>
                </Grid>
        </Border>
</Window>
