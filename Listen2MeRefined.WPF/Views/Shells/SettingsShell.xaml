<Window x:Class="Listen2MeRefined.WPF.Views.Shells.SettingsShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shells="clr-namespace:Listen2MeRefined.Application.ViewModels.Shells;assembly=Listen2MeRefined.Application"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance shells:SettingsShellViewModel}"
        Style="{DynamicResource BasicWindow}"
        ResizeMode="NoResize"
        Title="Settings"
        Height="620"
        Width="920">
    
    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>
    
    <Border BorderThickness="2" BorderBrush="{DynamicResource TertiaryBrush}" Background="{DynamicResource PrimaryBrush}" CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <components:TitleBar FontFamily="{Binding FontFamilyName}" 
                                 CenterText="Settings"
                                 ShowSettingsButton="False"
                                 ShowMinimizeButton="False"
                                 ShowMaximizeButton="False"
                                 ShowCloseButton="True"
                                 ShowTaskStatus="False"
                                 CloseCommand="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=CloseWindowCommand}"
                                 IsUpdateAvailableFeedbackVisible="False"/>

            <Border Grid.Row="1"
                    Margin="10,10,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="8"
                            Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl Margin="0,0,0,2"
                                          FontFamily="{Binding FontFamilyName}"
                                          ItemsSource="{Binding NavigationItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{DynamicResource SettingsNavButtonSurfaceStyle}"
                                                Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Route}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="{Binding IconKind}" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <ContentControl Grid.Column="2" Content="{Binding CurrentViewModel}" />
                </Grid>
            </Border>

            <components:WindowFooterBar Grid.Row="2"
                                        Margin="10,10,10,10"
                                        InfoText="Changes are applied immediately."
                                        PrimaryButtonText="Done"
                                        PrimaryButtonMinWidth="140"
                                        PrimaryClick="CloseWindow" />
        </Grid>
    </Border>
</Window>
