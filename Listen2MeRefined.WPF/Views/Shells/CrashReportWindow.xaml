<Window x:Class="Listen2MeRefined.WPF.Views.Shells.CrashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:popups="clr-namespace:Listen2MeRefined.WPF.Views.Popups"
        mc:Ignorable="d"
        d:DesignHeight="500"
        d:DesignWidth="680"
        Style="{DynamicResource BasicWindow}"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Width="680"
        Height="500"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Title="Unexpected Error">
    <Border BorderThickness="1"
            BorderBrush="{DynamicResource TertiaryBrush}"
            Background="{DynamicResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <popups:CrashReportPopup x:Name="CrashReportContent" />

            <!-- Footer strip -->
            <Border Grid.Row="1"
                    Style="{DynamicResource CrashReportFooterStripBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="PrimaryActionButton"
                            Grid.Column="1"
                            MinWidth="170"
                            Style="{DynamicResource CrashReportFooterPrimaryActionButton}"
                            Click="PrimaryActionButton_OnClick" />
                    <Button x:Name="SecondaryActionButton"
                            Grid.Column="2"
                            MinWidth="120"
                            Margin="6,0,0,0"
                            Style="{DynamicResource CrashReportFooterActionButton}"
                            Click="SecondaryActionButton_OnClick" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
