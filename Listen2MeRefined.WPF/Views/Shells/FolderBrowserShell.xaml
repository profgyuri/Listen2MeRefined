<Window x:Class="Listen2MeRefined.WPF.Views.Shells.FolderBrowserShell"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        xmlns:shells="clr-namespace:Listen2MeRefined.Application.ViewModels.Shells;assembly=Listen2MeRefined.Application"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance shells:FolderBrowserShellViewModel}"
        Style="{DynamicResource BasicWindow}"
        FontFamily="{Binding CurrentViewModel.FontFamilyName, Converter={StaticResource StringToFontFamily}}"
        Title="Folder Browser"
        Height="520"
        Width="860"
        MinHeight="470"
        MinWidth="760"
        PreviewKeyDown="FolderBrowserShell_OnPreviewKeyDown">
    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>

    <Border BorderThickness="2"
            BorderBrush="{DynamicResource TertiaryBrush}"
            Background="{DynamicResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0"
                                 CenterText="Folder Browser"
                                 ShowSettingsButton="False"
                                 ShowMinimizeButton="False"
                                 ShowMaximizeButton="False"
                                 ShowCloseButton="True" />

            <Border Grid.Row="1"
                    Style="{DynamicResource BorderContainer}"
                    Margin="10,10,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{DynamicResource DarkBorderContainer}"
                            Padding="0,6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <components:SectionHeader Title="Pinned"
                                                          IconKind="Pin"
                                                          ShowActionButton="False" />
                                <ListView Height="180"
                                          ItemsSource="{Binding CurrentViewModel.PinnedFolders}"
                                          SelectedItem="{Binding CurrentViewModel.SelectedPinnedFolder, Mode=TwoWay}"
                                          Style="{DynamicResource FolderBrowserListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource SecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding DataContext.CurrentViewModel.SelectPinnedFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>

                                <components:SectionHeader Title="Drives"
                                                          IconKind="Harddisk"
                                                          ShowActionButton="False"
                                                          Margin="0,4,0,0" />
                                <ListView Height="130"
                                          ItemsSource="{Binding CurrentViewModel.Drives}"
                                          SelectedItem="{Binding CurrentViewModel.SelectedDrive, Mode=TwoWay}"
                                          Style="{DynamicResource FolderBrowserListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource SecondaryBrush}" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding DataContext.CurrentViewModel.SelectDriveCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <ContentControl Grid.Column="2"
                                    Content="{Binding CurrentViewModel}" />
                </Grid>
            </Border>

            <components:WindowFooterBar Grid.Row="2"
                                        Margin="10,10,10,10"
                                        InfoText="Enter/Right to open. Left to go back. Ctrl+V jumps to clipboard path. Select adds folder to library."
                                        PrimaryButtonText="Select"
                                        PrimaryButtonMinWidth="110"
                                        ShowSecondaryButton="True"
                                        SecondaryButtonText="Cancel"
                                        SecondaryButtonMinWidth="110"
                                        PrimaryClick="SelectButton_Click"
                                        SecondaryClick="CancelButton_Click" />
        </Grid>
    </Border>
</Window>
