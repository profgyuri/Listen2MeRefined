<UserControl x:Class="Listen2MeRefined.WPF.Views.Popups.SongDroppedPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:popups="clr-namespace:Listen2MeRefined.Application.ViewModels.Popups;assembly=Listen2MeRefined.Application"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance popups:SongDroppedPopupViewModel}"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Foreground="{DynamicResource SecondaryBrush}"
                   TextWrapping="Wrap"
                   FontSize="14"
                   Text="This song's folder is not in your music folder list. Add it now?" />

        <TextBlock Grid.Row="1"
                   Margin="0,10,0,0"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource SecondaryDarkBrush}"
                   FontFamily="Consolas"
                   TextWrapping="Wrap"
                   Text="{Binding FolderPath}" />

        <CheckBox Grid.Row="2"
                  Margin="0,10,0,2"
                  Content="Don't ask again for this folder"
                  IsChecked="{Binding DontAskAgain, Mode=TwoWay}" />
    </Grid>
</UserControl>
