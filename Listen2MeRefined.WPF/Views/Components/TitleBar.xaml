<UserControl x:Class="Listen2MeRefined.WPF.Views.Components.TitleBar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignWidth="400">
    <Border Padding="10,4"
            BorderBrush="#3A3A3A"
            BorderThickness="0,0,0,1"
            Background="#232323">
        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    WindowChrome.IsHitTestVisibleInChrome="False"
                    CornerRadius="9"
                    BorderThickness="1"
                    BorderBrush="#3F3F3F"
                    Background="#2B2B2B"
                    Height="30"
                    Padding="8,4"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Listen2Me.ico"
                           Width="16"
                           Height="16"
                           SnapsToDevicePixels="True"
                           Margin="0,0,7,0" />
                    <TextBlock Text="Listen2Me Refined"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border Grid.Column="0"
                    Grid.ColumnSpan="3"
                    WindowChrome.IsHitTestVisibleInChrome="False"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Height="30"
                    Padding="10,4"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="#3D3D3D"
                    Background="#292929">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="6"
                             Height="6"
                             Fill="{StaticResource TertiaryBrush}"
                             Margin="0,0,6,0" />
                    <TextBlock Text="{Binding CenterText, ElementName=Root}"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Command="{Binding SettingsCommand, ElementName=Root}"
                        Style="{StaticResource ComponentTitleActionButton}"
                        Content="{materialDesign:PackIcon Kind=CogOutline,Size=15}"
                        Visibility="{Binding ShowSettingsButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Command="{Binding EffectiveMinimizeCommand, ElementName=Root}"
                        Style="{StaticResource ComponentTitleActionButton}"
                        Margin="6,0,0,0"
                        Content="{materialDesign:PackIcon Kind=WindowMinimize,Size=15}"
                        Visibility="{Binding ShowMinimizeButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Command="{Binding EffectiveToggleMaximizeCommand, ElementName=Root}"
                        Margin="6,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ComponentTitleActionButton}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ShowMaximizeButton, ElementName=Root}" Value="True" />
                                        <Condition Binding="{Binding IsMaximizeAvailable, ElementName=Root}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <materialDesign:PackIcon Width="15" Height="15">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Kind" Value="WindowMaximize" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMaximized, ElementName=Root}" Value="True">
                                        <Setter Property="Kind" Value="WindowRestore" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                </Button>

                <Button Command="{Binding EffectiveCloseCommand, ElementName=Root}"
                        Style="{StaticResource ComponentCloseTitleActionButton}"
                        Content="{materialDesign:PackIcon Kind=Close,Size=15}"
                        Margin="6,0,0,0"
                        Visibility="{Binding ShowCloseButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
