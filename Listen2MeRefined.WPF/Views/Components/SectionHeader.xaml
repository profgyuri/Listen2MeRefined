<UserControl x:Class="Listen2MeRefined.WPF.Views.Components.SectionHeader"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Background="#222222"
            BorderBrush="#393939"
            BorderThickness="1"
            CornerRadius="10"
            Padding="10,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="24"
                    Height="24"
                    CornerRadius="12"
                    VerticalAlignment="Center"
                    Background="{Binding AccentBrush, ElementName=Root}">
                <materialDesign:PackIcon Kind="{Binding IconKind, ElementName=Root}"
                                         Width="14"
                                         Height="14"
                                         Foreground="#1F1F1F"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                <TextBlock Style="{StaticResource AdvancedSearchToolbarTitleText}"
                           Text="{Binding Title, ElementName=Root}" />
                <TextBlock Style="{StaticResource AdvancedSearchToolbarLabelText}"
                           Text="{Binding Subtitle, ElementName=Root}"
                           Visibility="{Binding ShowSubtitle, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>

            <Button Grid.Column="2"
                    Style="{StaticResource ComponentQuickActionButton}"
                    Command="{Binding ActionCommand, ElementName=Root}"
                    ToolTip="{Binding ActionToolTip, ElementName=Root}"
                    Visibility="{Binding ShowActionButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="{Binding ActionIconKind, ElementName=Root}"
                                         Width="20"
                                         Height="20" />
            </Button>
        </Grid>
    </Border>
</UserControl>
