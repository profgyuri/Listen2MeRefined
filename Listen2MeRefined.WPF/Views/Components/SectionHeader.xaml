<UserControl x:Class="Listen2MeRefined.WPF.Views.Components.SectionHeader"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid Margin="10,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Width="20"
                Height="20"
                CornerRadius="10"
                VerticalAlignment="Center"
                Background="{DynamicResource TertiaryBrush}">
            <materialDesign:PackIcon Kind="{Binding IconKind, ElementName=Root}"
                                     Width="12"
                                     Height="12"
                                     Foreground="{DynamicResource PrimaryBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
        </Border>

        <StackPanel Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center">
            <TextBlock Style="{DynamicResource SectionHeaderTitleText}"
                       Text="{Binding Title, ElementName=Root}" />
            <TextBlock Style="{DynamicResource SectionHeaderSubtitleText}"
                       Text="{Binding Subtitle, ElementName=Root}"
                       Visibility="{Binding ShowSubtitle, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <Button Grid.Column="2"
                Style="{DynamicResource SectionHeaderPillButton}"
                Command="{Binding ActionCommand, ElementName=Root}"
                ToolTip="{Binding ActionToolTip, ElementName=Root}"
                Visibility="{Binding ShowActionButton, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ActionButtonText, ElementName=Root}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <materialDesign:PackIcon Kind="{Binding ActionIconKind, ElementName=Root}"
                                         Width="14"
                                         Height="14"
                                         VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
