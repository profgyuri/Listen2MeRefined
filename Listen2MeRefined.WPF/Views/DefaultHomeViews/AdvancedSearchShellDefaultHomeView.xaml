<UserControl x:Class="Listen2MeRefined.WPF.Views.DefaultHomeViews.AdvancedSearchShellDefaultHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:defaultHomeViewModels="clr-namespace:Listen2MeRefined.Application.ViewModels.DefaultHomeViewModels;assembly=Listen2MeRefined.Application"
             xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance defaultHomeViewModels:AdvancedSearchShellDefaultHomeViewModel}"
             d:DesignHeight="450" d:DesignWidth="600" >
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SearchCommand}" />
    </UserControl.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header strip: section header + filter input -->
        <Border Grid.Row="0"
                Style="{DynamicResource AdvancedSearchHeaderStripBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <components:SectionHeader Grid.Row="0"
                                          Title="Advanced Search Filters"
                                          Subtitle="Enter adds filter, Ctrl+Enter searches, Delete removes selected filter."
                                          ShowSubtitle="True"
                                          IconKind="Tune" />

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="TableColumnName"
                              Grid.Column="0"
                              ItemsSource="{Binding ColumnName}"
                              SelectedItem="{Binding SelectedColumnName}"
                              Style="{DynamicResource CustomComboBox}" />

                    <ComboBox x:Name="Relation"
                              Grid.Column="2"
                              ItemsSource="{Binding Relation}"
                              SelectedItem="{Binding SelectedRelation}"
                              Style="{DynamicResource CustomComboBox}" />

                    <Border Grid.Column="4"
                            Style="{DynamicResource AdvancedSearchInputBorder}">
                        <TextBox x:Name="GeneralInput"
                                 Style="{DynamicResource AdvancedSearchTextBoxStyle}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:TextFieldAssist.SuffixText="{Binding RangeSuffixText}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding AddCriteriaCommand}" />
                                <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </Border>

                    <Button x:Name="AddCriteria"
                            Grid.Column="6"
                            Style="{DynamicResource ComponentQuickActionButton}"
                            ToolTip="Add Filter"
                            Command="{Binding AddCriteriaCommand}"
                            Content="{materialDesign:PackIcon Kind=Plus, Size=20}"
                            Click="AddCriteriaButton_Click" />
                </Grid>
            </Grid>
        </Border>

        <!-- Content: criteria list -->
        <Grid Grid.Row="1" Margin="14,8,14,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="6" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Style="{DynamicResource AdvancedSearchToolbarTitleText}"
                           Text="Filters" />
                <TextBlock Grid.Column="1"
                           Style="{DynamicResource AdvancedSearchToolbarLabelText}"
                           Text="{Binding Criterias.Count, StringFormat={}{0} total}" />
            </Grid>

            <ListView x:Name="SearchCriterias"
                      Grid.Row="2"
                      ItemsSource="{Binding Criterias}"
                      SelectedItem="{Binding SelectedCriteria}"
                      ItemContainerStyle="{DynamicResource AdvancedSearchCriteriaListItem}"
                      Style="{DynamicResource AdvancedSearchCriteriaListView}">
                <ListView.InputBindings>
                    <KeyBinding Key="Delete" Command="{Binding DeleteItemCommand}" />
                </ListView.InputBindings>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Display}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource SecondaryBrush}" />

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Style="{DynamicResource AdvancedSearchMiniActionButton}"
                                        ToolTip="Edit"
                                        Command="{Binding DataContext.EditCriteriaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Click="EditCriteriaButton_Click"
                                        Content="{materialDesign:PackIcon Kind=Pencil, Size=14}" />
                                <Button Style="{DynamicResource AdvancedSearchMiniActionButton}"
                                        ToolTip="Duplicate"
                                        Command="{Binding DataContext.DuplicateCriteriaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="{materialDesign:PackIcon Kind=ContentCopy, Size=14}" />
                                <Button Style="{DynamicResource AdvancedSearchMiniActionButton}"
                                        ToolTip="Remove"
                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Content="{materialDesign:PackIcon Kind=DeleteOutline, Size=14}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Footer strip: status, match mode, actions -->
        <Border Grid.Row="2"
                Style="{DynamicResource AdvancedSearchFooterStripBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource ValidationErrorBrush}"
                               Text="{Binding ValidationMessage}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,2,0,0"
                               Foreground="{DynamicResource SecondaryDarkBrush}"
                               Text="{Binding SearchStatusMessage}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="8,0">
                    <RadioButton GroupName="MatchModeGroup"
                                 Style="{DynamicResource AdvancedSearchMatchModeRadioButton}"
                                 IsChecked="{Binding IsMatchAll, Mode=TwoWay}"
                                 Content="Match All" />
                    <RadioButton GroupName="MatchModeGroup"
                                 Style="{DynamicResource AdvancedSearchMatchModeRadioButton}"
                                 IsChecked="{Binding IsMatchAny, Mode=TwoWay}"
                                 Content="Match Any" />
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Clear All"
                        Command="{Binding ClearAllCommand}"
                        Style="{DynamicResource AdvancedSearchFooterActionButton}"
                        Margin="0,0,6,0" />

                <Button Grid.Column="3"
                        Content="Search"
                        Command="{Binding SearchCommand}"
                        Style="{DynamicResource AdvancedSearchPrimaryFooterActionButton}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
