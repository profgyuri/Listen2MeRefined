<UserControl x:Class="Listen2MeRefined.WPF.Views.DefaultHomeViews.FolderBrowserShellDefaultHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
             xmlns:defaultHomeViewModels="clr-namespace:Listen2MeRefined.Application.ViewModels.DefaultHomeViewModels;assembly=Listen2MeRefined.Application"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance defaultHomeViewModels:FolderBrowserShellDefaultHomeViewModel}"
             d:DesignHeight="300"
             d:DesignWidth="300">
    <UserControl.InputBindings>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding NavigateToClipboardPathCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <components:SectionHeader Title="Navigate To Folder"
                                  IconKind="FolderSearch"
                                  Subtitle="{Binding Folders.Count, StringFormat={}{0} items}"
                                  ShowSubtitle="True"
                                  ShowActionButton="False" />

        <Border Grid.Row="2"
                Style="{DynamicResource FolderBrowserFilterTextBoxBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Kind="FilterOutline"
                                         Width="16"
                                         Height="16"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource SecondaryDarkBrush}" />

                <TextBox x:Name="FilterTextBox"
                         Grid.Column="1"
                         Height="34"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource SecondaryBrush}"
                         CaretBrush="{DynamicResource TertiaryBrush}"
                         VerticalContentAlignment="Center"
                         materialDesign:HintAssist.Hint="Filter current view..."
                         materialDesign:HintAssist.Foreground="{DynamicResource SecondaryDarkBrush}"
                         Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <ListView x:Name="FolderList"
                  Grid.Row="4"
                  ItemsSource="{Binding Folders}"
                  SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                  Style="{DynamicResource FolderBrowserListView}">
            <ListView.InputBindings>
                <KeyBinding Key="Return" Command="{Binding NavigateIntoSelectedCommand}" />
                <KeyBinding Key="Right" Command="{Binding NavigateIntoSelectedCommand}" />
                <KeyBinding Key="Left" Command="{Binding NavigateParentCommand}" />
                <KeyBinding Key="Back" Command="{Binding NavigateParentCommand}" />
            </ListView.InputBindings>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="FolderOutline"
                                                 Width="14"
                                                 Height="14"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource SecondaryDarkBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding}"
                                   Foreground="{DynamicResource SecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseDoubleClick">
                    <i:InvokeCommandAction Command="{Binding NavigateIntoSelectedCommand}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ListView>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Style="{DynamicResource FolderBrowserFilterTextBoxBorder}">
                <TextBlock x:Name="PathTextBlock"
                           Foreground="{DynamicResource SecondaryBrush}"
                           Background="Transparent"
                           Height="36"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding FullPath}"
                           Text="{Binding FullPath}" />
            </Border>
            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Content="Pin Current"
                    Command="{Binding TogglePinCommand}"
                    Style="{DynamicResource FolderBrowserFooterActionButton}"
                    MinWidth="108" />
        </Grid>

        <TextBlock Grid.Row="7"
                   Margin="4,6,0,0"
                   Foreground="{DynamicResource ValidationErrorBrush}"
                   FontSize="11"
                   Text="{Binding ValidationMessage}"
                   Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}" />
    </Grid>
</UserControl>
