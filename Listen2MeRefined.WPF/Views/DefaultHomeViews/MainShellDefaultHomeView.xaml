<UserControl x:Class="Listen2MeRefined.WPF.Views.DefaultHomeViews.MainShellDefaultHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Listen2MeRefined.WPF.Views.DefaultHomeViews"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:wpf="clr-namespace:Listen2MeRefined.WPF"
             xmlns:utils="clr-namespace:Listen2MeRefined.WPF.Utils"
             xmlns:defaultHomeViewModels="clr-namespace:Listen2MeRefined.Application.ViewModels.DefaultHomeViewModels;assembly=Listen2MeRefined.Application"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance defaultHomeViewModels:MainShellDefaultHomeViewModel}"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Now Playing strip -->
        <Border Style="{DynamicResource NowPlayingStripBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Full-width waveform -->
                <Border Grid.Row="0"
                        Style="{DynamicResource NowPlayingWaveformBorder}"
                        DataContext="{Binding PlaybackControlsViewModel}">
                    <Grid>
                        <wpf:WaveSlider Style="{DynamicResource NoHaloSlider}"
                                        Foreground="{DynamicResource TertiaryBrush}"
                                        utils:WaveformViewportSyncBehavior.IsEnabled="True"
                                        WaveBitmap="{Binding WaveForm}"
                                        Minimum="0"
                                        Maximum="{Binding TotalTime}"
                                        Value="{Binding CurrentTime}"
                                        MinHeight="48"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Margin="6,0" />
                    </Grid>
                </Border>

                <!-- Transport strip: TrackInfo | Buttons+Time | Volume -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MaxWidth="300" />
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" MaxWidth="300" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Track info -->
                    <ContentControl Grid.Column="0"
                                    Content="{Binding TrackInfoViewModel}"
                                    VerticalAlignment="Center" />

                    <!-- Center: Transport controls + time -->
                    <ContentControl Grid.Column="1"
                                    Content="{Binding PlaybackControlsViewModel}"
                                    VerticalAlignment="Center" />

                    <!-- Right: Volume -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                DataContext="{Binding PlaybackControlsViewModel}">
                        <Button Style="{DynamicResource NowPlayingVolumeButton}"
                                Command="{Binding ToggleMuteCommand}"
                                ToolTip="Mute / Unmute">
                            <materialDesign:PackIcon Kind="{Binding VolumeIconKind}" Width="14" Height="14" />
                        </Button>
                        <Slider Width="84"
                                Margin="8,0,0,0"
                                Minimum="0"
                                Maximum="1"
                                Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Content view toggle -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="12,8,12,0">
            <Button Command="{Binding ShowPlaylistViewCommand}"
                    Cursor="Hand"
                    Margin="0,0,4,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ToggleBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="PlaylistMusic" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Playlist" FontSize="12" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlaylistViewActive}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TertiaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Command="{Binding ShowSearchResultsViewCommand}"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="10,5"/>
                        <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ToggleBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Magnify" Width="14" Height="14"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Search Results" FontSize="12" FontWeight="SemiBold"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlaylistViewActive}" Value="False">
                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TertiaryBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Content panel (switches between search results and playlist pane) -->
        <ContentControl Grid.Row="2"
                        Content="{Binding CurrentContentViewModel}"
                        Margin="12,8,12,8"/>

        <!-- Search bar -->
        <ContentControl Grid.Row="3" Content="{Binding SearchbarViewModel}" />
    </Grid>
</UserControl>
