<Window x:Class="Listen2MeRefined.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:Listen2MeRefined.Infrastructure.Mvvm;assembly=Listen2MeRefined.Infrastructure"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:SettingsWindowViewModel}"
        Style="{StaticResource BasicWindow}"
        FontFamily="{Binding SelectedFontFamily}"
        ResizeMode="NoResize"
        Title="Settings"
        Height="620"
        Width="920">

    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="{StaticResource TertiaryBrush}" />
        </Style>

        <Style x:Key="TitleActionButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="BtnBorder" Property="Background" Value="#353535" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#242424" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleActionButton" TargetType="Button" BasedOn="{StaticResource TitleActionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#970000" />
                    <Setter Property="BorderBrush" Value="#970000" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6F0000" />
                    <Setter Property="BorderBrush" Value="#6F0000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsNavTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="#AFAFAF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Width" Value="188" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#2D2D2D"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#353535" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#383838" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#232323" />
            <Setter Property="BorderBrush" Value="#393939" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8A8A8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BFBFBF" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource InteractionButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="Background" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="BtnBorder" Property="Background" Value="#383838" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#262626" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Border BorderThickness="2"
            BorderBrush="{StaticResource TertiaryBrush}"
            Background="{StaticResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="10,4"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1"
                    Background="#232323">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            WindowChrome.IsHitTestVisibleInChrome="False"
                            CornerRadius="9"
                            BorderThickness="1"
                            BorderBrush="#3F3F3F"
                            Background="#2B2B2B"
                            Height="30"
                            Padding="8,4"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/Listen2Me.ico"
                                   Width="16"
                                   Height="16"
                                   SnapsToDevicePixels="True"
                                   Margin="0,0,7,0" />
                            <TextBlock Text="Listen2Me Refined"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            WindowChrome.IsHitTestVisibleInChrome="False"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Height="30"
                            Padding="10,4"
                            CornerRadius="10"
                            BorderThickness="1"
                            BorderBrush="#3D3D3D"
                            Background="#292929">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6"
                                     Height="6"
                                     Fill="{StaticResource TertiaryBrush}"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="Settings"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource CloseTitleActionButton}"
                                Content="{materialDesign:PackIcon Kind=Close,Size=15}"
                                Click="CloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="10,10,10,0"
                    Background="#272727"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <TabControl Background="Transparent"
                            BorderThickness="0"
                            TabStripPlacement="Left">
                    <TabControl.Resources>
                        <Style TargetType="TabItem" BasedOn="{StaticResource SettingsNavTabItem}" />
                    </TabControl.Resources>
                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Tune" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="General" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="General Preferences" />
                                        <TextBlock Style="{StaticResource SectionDescriptionStyle}" Text="Basic app behavior and update policy." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Font family:" />
                                        <ComboBox Grid.Column="1"
                                                  x:Name="FontFamilyComboBox"
                                                  Style="{StaticResource CustomComboBox}"
                                                  SelectedItem="{Binding SelectedFontFamily}"
                                                  ItemsSource="{Binding FontFamilies}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        </Grid>

                                        <CheckBox IsChecked="{Binding AutoCheckUpdatesOnStartup}"
                                                  Content="Automatically check for updates on startup"
                                                  Margin="0,0,0,10" />
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Style="{StaticResource ActionButton}"
                                                MinWidth="130"
                                                Content="Check Now"
                                                Command="{Binding CheckForUpdatesNowCommand}" />
                                        <Button Style="{StaticResource ActionButton}"
                                                MinWidth="130"
                                                Margin="10,0,0,0"
                                                Content="{materialDesign:PackIcon Kind=Download, Size=16}"
                                                ToolTip="Download latest release"
                                                Command="{Binding OpenBrowserForUpdateCommand}"
                                                Visibility="{Binding IsUpdateButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource SectionDescriptionStyle}" Text="{Binding UpdateAvailableText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="VolumeHigh" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Playback" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Playback" />
                                        <TextBlock Style="{StaticResource SectionDescriptionStyle}" Text="Audio output and startup playback defaults." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Audio output:" />
                                        <ComboBox Grid.Column="1"
                                                  x:Name="AudioOutputComboBox"
                                                  Style="{StaticResource CustomComboBox}"
                                                  SelectedItem="{Binding SelectedAudioOutputDevice}"
                                                  ItemsSource="{Binding AudioOutputDevices}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <TextBlock Grid.Row="1" Style="{StaticResource FieldLabelStyle}" Text="Startup volume:" />
                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Slider Width="240"
                                                    Minimum="0"
                                                    Maximum="100"
                                                    TickFrequency="5"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding StartupVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="10,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding StartupVolumePercent, StringFormat={}{0}%}" />
                                        </StackPanel>

                                        <CheckBox Grid.Row="2"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0,12,0,0"
                                                  IsChecked="{Binding StartMuted}"
                                                  Content="Start muted" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderMusicOutline" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Library" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Library" />
                                        <TextBlock Style="{StaticResource SectionDescriptionStyle}" Text="Folders and scan behavior for your local library." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ListView Grid.RowSpan="2"
                                                  Height="180"
                                                  Margin="0,0,10,0"
                                                  Style="{StaticResource VirtualizedListView}"
                                                  ItemsSource="{Binding Folders}"
                                                  SelectedItem="{Binding SelectedFolder}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{StaticResource SecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.ToolTip>
                                                            <ToolTip Visibility="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget, Converter={StaticResource TrimmedTextBlockVisibilityConverter}}"
                                                                     Content="{Binding}" />
                                                        </TextBlock.ToolTip>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <Button x:Name="OpenFolderBrowser"
                                                Grid.Column="1"
                                                Style="{StaticResource IconActionButton}"
                                                Click="OpenFolderBrowser_Click"
                                                Content="{materialDesign:PackIcon Kind=FolderAddOutline, Size=18}"
                                                ToolTip="Browse and add folder"
                                                Margin="0,0,0,10" />
                                        <Button x:Name="RemoveFolder"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{StaticResource IconActionButton}"
                                                Command="{Binding RemoveFolderCommand}"
                                                IsEnabled="{Binding SelectedFolder, Converter={StaticResource IsFolderSelectedConverter}}"
                                                Content="{materialDesign:PackIcon Kind=FolderRemoveOutline, Size=18}"
                                                ToolTip="Remove selected folder" />
                                        </Grid>

                                        <CheckBox IsChecked="{Binding ScanOnStartup}" Content="Scan folders on startup" Margin="0,0,0,6" />
                                        <CheckBox IsChecked="{Binding AutoScanOnFolderAdd}" Content="Scan newly added folders immediately" Margin="0,0,0,10" />
                                        <Button Style="{StaticResource ActionButton}"
                                                HorizontalAlignment="Left"
                                                MinWidth="130"
                                                Content="Rescan Now"
                                                Command="{Binding ForceScanCommand}"
                                                ToolTip="Scan all configured folders now" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BellOutline" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Hooks &amp; Alerts" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Notifications and Hooks" />
                                        <TextBlock Style="{StaticResource SectionDescriptionStyle}" Text="Global key hooks and corner popup behavior." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Global media keys:" />
                                        <CheckBox Grid.Column="1" IsChecked="{Binding EnableGlobalMediaKeys}" Content="Enable global media key shortcuts" />

                                        <TextBlock Grid.Row="1" Style="{StaticResource FieldLabelStyle}" Text="Corner popup:" />
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <CheckBox IsChecked="{Binding EnableCornerNowPlayingPopup}" Content="Enable corner now-playing popup" Margin="0,0,0,8" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock Width="170" VerticalAlignment="Center" Text="Trigger area:" />
                                                <Slider Width="140"
                                                        Minimum="4"
                                                        Maximum="64"
                                                        TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding CornerTriggerSizePx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding CornerTriggerSizePx, StringFormat={}{0}px}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Width="170" VerticalAlignment="Center" Text="Debounce:" />
                                                <Slider Width="140"
                                                        Minimum="5"
                                                        Maximum="200"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding CornerTriggerDebounceMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding CornerTriggerDebounceMs, StringFormat={}{0} ms}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,0" Text="Notification window:" />
                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Margin="0,10,0,0"
                                                  x:Name="NotificationWindowComboBox"
                                                  Style="{StaticResource CustomComboBox}"
                                                  SelectedItem="{Binding SelectedNewSongWindowPosition}"
                                                  ItemsSource="{Binding NewSongWindowPositions}" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Advanced" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Advanced" />
                                        <TextBlock Style="{StaticResource SectionDescriptionStyle}" Text="Danger zone. Clearing metadata removes songs, playlists, and folder registrations from the local database." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCard}" BorderBrush="#6B3D3D" Background="#2A2121">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource SectionDescriptionStyle}"
                                                   Foreground="#E2A4A4"
                                                   Text="This action cannot be undone. Use it only when you want a full local reset."
                                                   Margin="0,0,0,10" />
                                        <StackPanel Orientation="Horizontal">
                                        <Button x:Name="ClearMetadataButton"
                                                Style="{StaticResource ActionButton}"
                                                MinWidth="150"
                                                Content="Clear Metadata"
                                                Command="{Binding ClearMetadataCommand}"
                                                Visibility="{Binding IsClearMetadataButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button x:Name="CancelClearMetadataButton"
                                                    Style="{StaticResource ActionButton}"
                                                    MinWidth="150"
                                                    Margin="10,0,0,0"
                                                    Content="{Binding CancelClearMetadataButtonContent}"
                                                    Visibility="{Binding IsCancelClearMetadataButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Command="{Binding CancelClearMetadataCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Row="2"
                    Margin="10,10,10,10"
                    Background="#232323"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Style="{StaticResource SectionDescriptionStyle}"
                               VerticalAlignment="Center"
                               Text="Changes are applied immediately." />

                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Style="{StaticResource ActionButton}"
                            MinWidth="140"
                            Content="Done"
                            Click="CloseButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
