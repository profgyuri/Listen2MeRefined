<Window x:Class="Listen2MeRefined.WPF.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        xmlns:viewModels="clr-namespace:Listen2MeRefined.Infrastructure.ViewModels;assembly=Listen2MeRefined.Infrastructure"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:SettingsWindowViewModel}"
        Style="{DynamicResource BasicWindow}"
        FontFamily="{Binding SelectedFontFamily}"
        ResizeMode="NoResize"
        Title="Settings"
        Height="620"
        Width="920">

    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>

    <Border BorderThickness="2"
            BorderBrush="{DynamicResource TertiaryBrush}"
            Background="{DynamicResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0"
                                 CenterText="Settings"
                                 ShowSettingsButton="False"
                                 ShowMinimizeButton="False"
                                 ShowMaximizeButton="False"
                                 ShowCloseButton="True"
                                 CloseCommand="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=HideWindowCommand}" />

            <Border Grid.Row="1"
                    Margin="10,10,10,0"
                    Background="#272727"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <TabControl Background="Transparent"
                            BorderThickness="0"
                            TabStripPlacement="Left"
                            ItemContainerStyle="{DynamicResource SettingsNavTabItemStyle}">
                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Tune" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="General" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="General Preferences" />
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="Basic app behavior and update policy." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <components:FormFieldRow Margin="0,0,0,10"
                                                                 Label="Font family:"
                                                                 LabelWidth="170">
                                            <components:FormFieldRow.FieldContent>
                                                <ComboBox Style="{DynamicResource CustomComboBox}"
                                                          SelectedItem="{Binding SelectedFontFamily}"
                                                          ItemsSource="{Binding FontFamilies}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" FontFamily="{Binding}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </components:FormFieldRow.FieldContent>
                                        </components:FormFieldRow>

                                        <components:FormFieldRow Margin="0,0,0,10"
                                                                 Label="Theme:"
                                                                 LabelWidth="170">
                                            <components:FormFieldRow.FieldContent>
                                                <ComboBox Style="{DynamicResource CustomComboBox}"
                                                          SelectedItem="{Binding SelectedThemeMode}"
                                                          ItemsSource="{Binding ThemeModes}" />
                                            </components:FormFieldRow.FieldContent>
                                        </components:FormFieldRow>

                                        <components:FormFieldRow Margin="0,0,0,10"
                                                                 Label="Accent color:"
                                                                 LabelWidth="170">
                                            <components:FormFieldRow.FieldContent>
                                                <ComboBox Style="{DynamicResource CustomComboBox}"
                                                          SelectedItem="{Binding SelectedAccentColor}"
                                                          ItemsSource="{Binding AccentColors}" />
                                            </components:FormFieldRow.FieldContent>
                                        </components:FormFieldRow>

                                        <CheckBox IsChecked="{Binding AutoCheckUpdatesOnStartup}"
                                                  Content="Automatically check for updates on startup"
                                                  Margin="0,0,0,10" />
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Button Style="{DynamicResource SettingsActionButton}"
                                                MinWidth="130"
                                                Content="Check Now"
                                                Command="{Binding CheckForUpdatesNowCommand}" />
                                        <Button Style="{DynamicResource SettingsActionButton}"
                                                MinWidth="130"
                                                Margin="10,0,0,0"
                                                Content="{materialDesign:PackIcon Kind=Download, Size=16}"
                                                ToolTip="Download latest release"
                                                Command="{Binding OpenBrowserForUpdateCommand}"
                                                Visibility="{Binding IsUpdateButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="{Binding UpdateAvailableText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="VolumeHigh" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Playback" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="Playback" />
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="Audio output and startup playback defaults." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <components:FormFieldRow Grid.ColumnSpan="2"
                                                                 Label="Audio output:"
                                                                 LabelWidth="200">
                                            <components:FormFieldRow.FieldContent>
                                                <ComboBox Style="{DynamicResource CustomComboBox}"
                                                          Foreground="{DynamicResource SecondaryBrush}"
                                                          SelectedItem="{Binding SelectedAudioOutputDevice}"
                                                          ItemsSource="{Binding AudioOutputDevices}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </components:FormFieldRow.FieldContent>
                                        </components:FormFieldRow>

                                        <components:LabeledSliderRow Grid.Row="1"
                                                                     Grid.ColumnSpan="2"
                                                                     Label="Startup volume:"
                                                                     LabelWidth="200"
                                                                     SliderWidth="240"
                                                                     Minimum="0"
                                                                     Maximum="100"
                                                                     TickFrequency="5"
                                                                     IsSnapToTickEnabled="True"
                                                                     Value="{Binding StartupVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     ValueSuffix="%" />

                                        <CheckBox Grid.Row="2"
                                                  Grid.ColumnSpan="2"
                                                  Margin="0,12,0,0"
                                                  IsChecked="{Binding StartMuted}"
                                                  Content="Start muted" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderMusicOutline" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Library" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="Library" />
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="Folders and scan behavior for your local library." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ListView Grid.RowSpan="2"
                                                  Height="180"
                                                  Margin="0,0,10,0"
                                                  Style="{DynamicResource VirtualizedListView}"
                                                  ItemsSource="{Binding Folders}"
                                                  SelectedItem="{Binding SelectedFolder}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource SecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <TextBlock.ToolTip>
                                                            <ToolTip Visibility="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget, Converter={StaticResource TrimmedTextBlockVisibilityConverter}}"
                                                                     Content="{Binding}" />
                                                        </TextBlock.ToolTip>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <Button x:Name="OpenFolderBrowser"
                                                Grid.Column="1"
                                                Style="{DynamicResource SettingsIconActionButton}"
                                                Click="OpenFolderBrowser_Click"
                                                Content="{materialDesign:PackIcon Kind=FolderAddOutline, Size=18}"
                                                ToolTip="Browse and add folder"
                                                Margin="0,0,0,10" />
                                        <Button x:Name="RemoveFolder"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Style="{DynamicResource SettingsIconActionButton}"
                                                Command="{Binding RemoveFolderCommand}"
                                                IsEnabled="{Binding SelectedFolder, Converter={StaticResource IsFolderSelectedConverter}}"
                                                Content="{materialDesign:PackIcon Kind=FolderRemoveOutline, Size=18}"
                                                ToolTip="Remove selected folder" />
                                        </Grid>

                                        <CheckBox IsChecked="{Binding SelectedFolderIncludeSubdirectories}"
                                                  IsEnabled="{Binding SelectedFolder, Converter={StaticResource IsFolderSelectedConverter}}"
                                                  Content="Scan selected folder recursively"
                                                  Margin="0,0,0,6" />
                                        <CheckBox IsChecked="{Binding ScanOnStartup}" Content="Scan folders on startup" Margin="0,0,0,6" />
                                        <CheckBox IsChecked="{Binding AutoScanOnFolderAdd}" Content="Scan newly added folders immediately" Margin="0,0,0,10" />
                                        <Button Style="{DynamicResource SettingsActionButton}"
                                                HorizontalAlignment="Left"
                                                MinWidth="130"
                                                Content="Rescan Now"
                                                Command="{Binding ForceScanCommand}"
                                                ToolTip="Scan all configured folders now" />

                                        <Border Margin="0,12,0,0"
                                                Padding="10"
                                                Background="#202020"
                                                BorderBrush="#363636"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}"
                                                           Text="Background task status in title bar" />
                                                <CheckBox Margin="0,8,0,0"
                                                          IsChecked="{Binding ShowTaskPercentage}"
                                                          Content="Show progress percentage" />
                                                <components:LabeledSliderRow Margin="0,8,0,0"
                                                                             Label="Percent step:"
                                                                             LabelWidth="170"
                                                                             SliderWidth="180"
                                                                             Minimum="1"
                                                                             Maximum="25"
                                                                             TickFrequency="1"
                                                                             IsSnapToTickEnabled="True"
                                                                             Value="{Binding TaskPercentageReportInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             ValueSuffix=" %" />

                                                <CheckBox Margin="0,10,0,0"
                                                          IsChecked="{Binding ShowScanMilestoneCount}"
                                                          Content="Show file-count milestones" />
                                                <components:FormFieldRow Margin="0,8,0,0"
                                                                         Label="Count basis:"
                                                                         LabelWidth="170">
                                                    <components:FormFieldRow.FieldContent>
                                                        <ComboBox Style="{DynamicResource CustomComboBox}"
                                                                  SelectedItem="{Binding SelectedScanMilestoneBasis}"
                                                                  ItemsSource="{Binding ScanMilestoneBases}" />
                                                    </components:FormFieldRow.FieldContent>
                                                </components:FormFieldRow>
                                                <components:LabeledSliderRow Margin="0,8,0,0"
                                                                             Label="Milestone every:"
                                                                             LabelWidth="170"
                                                                             SliderWidth="180"
                                                                             Minimum="5"
                                                                             Maximum="500"
                                                                             TickFrequency="5"
                                                                             IsSnapToTickEnabled="True"
                                                                             Value="{Binding ScanMilestoneInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             ValueSuffix=" files"
                                                                             IsEnabled="{Binding ShowScanMilestoneCount}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="Folder Browser Speed" />
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}"
                                                   Margin="0,0,0,10"
                                                   Text="Tune how quickly the folder browser returns to common locations." />

                                        <Grid Margin="0,0,0,10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Style="{DynamicResource SettingsFieldLabelText}" Text="Start location:" />
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding FolderBrowserStartAtLastLocation}"
                                                      Content="Open browser at the last browsed folder when possible" />
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="120" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Style="{DynamicResource SettingsFieldLabelText}" Text="Pinned folders" />
                                            <ListView Grid.Row="1"
                                                      Height="120"
                                                      Margin="0,6,0,8"
                                                      Style="{DynamicResource VirtualizedListView}"
                                                      ItemsSource="{Binding PinnedFolders}"
                                                      SelectedItem="{Binding SelectedPinnedFolder}">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="{DynamicResource SecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Button Style="{DynamicResource SettingsActionButton}"
                                                        MinWidth="110"
                                                        Content="Remove Pin"
                                                        Command="{Binding RemovePinnedFolderCommand}" />
                                                <Button Style="{DynamicResource SettingsActionButton}"
                                                        MinWidth="130"
                                                        Margin="8,0,0,0"
                                                        Content="Clear Invalid Pins"
                                                        Command="{Binding ClearInvalidPinsCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="BellOutline" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Hooks &amp; Alerts" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="Notifications and Hooks" />
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="Global key hooks and corner popup behavior." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Style="{DynamicResource SettingsFieldLabelText}" Text="Global media keys:" />
                                        <CheckBox Grid.Column="1" IsChecked="{Binding EnableGlobalMediaKeys}" Content="Enable global media key shortcuts" />

                                        <TextBlock Grid.Row="1" Style="{DynamicResource SettingsFieldLabelText}" Text="Corner popup:" />
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <CheckBox IsChecked="{Binding EnableCornerNowPlayingPopup}" Content="Enable corner now-playing popup" Margin="0,0,0,8" />
                                            <components:LabeledSliderRow Margin="0,0,0,8"
                                                                         Label="Trigger area:"
                                                                         LabelWidth="170"
                                                                         SliderWidth="140"
                                                                         Minimum="4"
                                                                         Maximum="64"
                                                                         TickFrequency="1"
                                                                         IsSnapToTickEnabled="True"
                                                                         Value="{Binding CornerTriggerSizePx, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         ValueSuffix="px" />
                                            <components:LabeledSliderRow Label="Debounce:"
                                                                         LabelWidth="170"
                                                                         SliderWidth="140"
                                                                         Minimum="5"
                                                                         Maximum="200"
                                                                         TickFrequency="5"
                                                                         IsSnapToTickEnabled="True"
                                                                         Value="{Binding CornerTriggerDebounceMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         ValueSuffix=" ms" />
                                        </StackPanel>

                                        <components:FormFieldRow Grid.Row="2"
                                                                 Grid.ColumnSpan="2"
                                                                 Margin="0,10,0,0"
                                                                 Label="Notification window:"
                                                                 LabelWidth="210">
                                            <components:FormFieldRow.FieldContent>
                                                <ComboBox Style="{DynamicResource CustomComboBox}"
                                                          SelectedItem="{Binding SelectedNewSongWindowPosition}"
                                                          ItemsSource="{Binding NewSongWindowPositions}" />
                                            </components:FormFieldRow.FieldContent>
                                        </components:FormFieldRow>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Cursor="Hand">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircleOutline" Width="16" Height="16" Margin="0,0,8,0" />
                                <TextBlock Text="Advanced" />
                            </StackPanel>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12,0,0,0">
                                <Border Style="{DynamicResource SettingsSectionCard}">
                                    <StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="Advanced" />
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="Danger zone. Clearing metadata removes songs, playlists, and folder registrations from the local database." />
                                    </StackPanel>
                                </Border>

                                <Border Style="{DynamicResource SettingsSectionCard}" BorderBrush="#6B3D3D" Background="#2A2121">
                                    <StackPanel>
                                        <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}"
                                                   Foreground="#E2A4A4"
                                                   Text="This action cannot be undone. Use it only when you want a full local reset."
                                                   Margin="0,0,0,10" />
                                        <StackPanel Orientation="Horizontal">
                                        <Button x:Name="ClearMetadataButton"
                                                Style="{DynamicResource SettingsActionButton}"
                                                MinWidth="150"
                                                Content="Clear Metadata"
                                                Command="{Binding ClearMetadataCommand}"
                                                Visibility="{Binding IsClearMetadataButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button x:Name="CancelClearMetadataButton"
                                                    Style="{DynamicResource SettingsActionButton}"
                                                    MinWidth="150"
                                                    Margin="10,0,0,0"
                                                    Content="{Binding CancelClearMetadataButtonContent}"
                                                    Visibility="{Binding IsCancelClearMetadataButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Command="{Binding CancelClearMetadataCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <components:WindowFooterBar Grid.Row="2"
                                        Margin="10,10,10,10"
                                        InfoText="Changes are applied immediately."
                                        PrimaryButtonText="Done"
                                        PrimaryButtonMinWidth="140"
                                        PrimaryClick="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
