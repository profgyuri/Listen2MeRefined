<Window x:Class="Listen2MeRefined.WPF.Views.AdvancedSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Listen2MeRefined.Infrastructure.Mvvm;assembly=Listen2MeRefined.Infrastructure"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:AdvancedSearchViewModel}"
        Style="{StaticResource BasicWindow}"
        ResizeMode="CanResizeWithGrip"
        MinHeight="460"
        MinWidth="640"
        Title="Advanced Search"
        Height="540"
        Width="760"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.InputBindings>
        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SearchCommand}" />
    </Window.InputBindings>

    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="{StaticResource TertiaryBrush}" />
        </Style>

        <Style x:Key="ToolbarTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ToolbarLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A8A8A8" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="QuickActionButton" TargetType="Button" BasedOn="{StaticResource InteractionButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="38" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
            <Setter Property="Background" Value="#2E2E2E" />
            <Setter Property="Foreground" Value="{StaticResource TertiaryBrush}" />
        </Style>

        <Style x:Key="CriteriaListView" TargetType="ListView" BasedOn="{StaticResource VirtualizedListView}">
            <Setter Property="Background" Value="#232323" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style x:Key="CriteriaListItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="BorderBrush" Value="#3B3B3B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="8,6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#313131" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource TertiaryDarkBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniActionButton" TargetType="Button" BasedOn="{StaticResource InteractionButton}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#5A5A5A" />
            <Setter Property="Background" Value="#343434" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
        </Style>

    </Window.Resources>

    <Border BorderThickness="2"
            BorderBrush="{StaticResource TertiaryBrush}"
            Background="{StaticResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0"
                                 CenterText="Advanced Search"
                                 ShowSettingsButton="False"
                                 ShowMinimizeButton="False"
                                 ShowMaximizeButton="True"
                                 ShowCloseButton="True" />

            <Border Grid.Row="1"
                    Margin="10"
                    Padding="10"
                    Background="#272727"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#222222"
                            BorderBrush="#393939"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="24"
                                    Height="24"
                                    Background="{StaticResource TertiaryBrush}"
                                    CornerRadius="12"
                                    VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="Tune"
                                                         Width="14"
                                                         Height="14"
                                                         Foreground="#1F1F1F"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource ToolbarTitleText}" Text="Advanced Search Filters" />
                                <TextBlock Style="{StaticResource ToolbarLabelText}" Text="Enter adds filter, Ctrl+Enter searches, Delete removes selected filter." />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#232323"
                            BorderBrush="#393939"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.ColumnSpan="4"
                                       Style="{StaticResource ToolbarLabelText}"
                                       Text="New Filter" />

                            <ComboBox x:Name="TableColumnName"
                                      Grid.Row="1"
                                      Grid.Column="0"
                                      ItemsSource="{Binding ColumnName}"
                                      SelectedItem="{Binding SelectedColumnName}"
                                      Style="{StaticResource CustomComboBox}"
                                      Margin="0,6,6,0" />

                            <ComboBox x:Name="Relation"
                                      Grid.Row="1"
                                      Grid.Column="1"
                                      ItemsSource="{Binding Relation}"
                                      SelectedItem="{Binding SelectedRelation}"
                                      Style="{StaticResource CustomComboBox}"
                                      Margin="0,6,6,0" />

                            <Border Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,6,6,0"
                                    Background="#2A2A2A"
                                    BorderBrush="#3D3D3D"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8,0">
                                <TextBox x:Name="GeneralInput"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:TextFieldAssist.SuffixText="{Binding RangeSuffixText}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding AddCriteriaCommand}" />
                                        <KeyBinding Key="Enter" Modifiers="Ctrl" Command="{Binding SearchCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                            </Border>

                            <Button x:Name="AddCriteria"
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Margin="0,6,0,0"
                                    Style="{StaticResource QuickActionButton}"
                                    ToolTip="Add Filter"
                                    Command="{Binding AddCriteriaCommand}"
                                    Content="{materialDesign:PackIcon Kind=Plus, Size=20}"
                                    Click="AddCriteriaButton_Click" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Background="#222222"
                            BorderBrush="#393939"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Style="{StaticResource ToolbarTitleText}"
                                       Text="Filters" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Style="{StaticResource ToolbarLabelText}"
                                       Text="{Binding Criterias.Count, StringFormat={}{0} total}" />

                            <ListView x:Name="SearchCriterias"
                                      Grid.Row="2"
                                      Grid.ColumnSpan="2"
                                      ItemsSource="{Binding Criterias}"
                                      SelectedItem="{Binding SelectedCriteria}"
                                      ItemContainerStyle="{StaticResource CriteriaListItem}"
                                      Style="{StaticResource CriteriaListView}">
                                <ListView.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding DeleteItemCommand}" />
                                </ListView.InputBindings>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding Display}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource SecondaryBrush}" />

                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource MiniActionButton}"
                                                        ToolTip="Edit"
                                                        Command="{Binding DataContext.EditCriteriaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Click="EditCriteriaButton_Click"
                                                        Content="{materialDesign:PackIcon Kind=Pencil, Size=14}" />
                                                <Button Style="{StaticResource MiniActionButton}"
                                                        ToolTip="Duplicate"
                                                        Command="{Binding DataContext.DuplicateCriteriaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{materialDesign:PackIcon Kind=ContentCopy, Size=14}" />
                                                <Button Style="{StaticResource MiniActionButton}"
                                                        ToolTip="Remove"
                                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{materialDesign:PackIcon Kind=DeleteOutline, Size=14}" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="0"
                                    Orientation="Vertical">
                            <TextBlock Foreground="#E26A6A"
                                       Text="{Binding ValidationMessage}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,0"
                                       Foreground="#A8A8A8"
                                       Text="{Binding SearchStatusMessage}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <RadioButton GroupName="MatchModeGroup"
                                         Style="{StaticResource MaterialDesignTabRadioButton}"
                                         Foreground="{DynamicResource TertiaryBrush}"
                                         BorderBrush="{DynamicResource TertiaryBrush}"
                                         IsChecked="{Binding IsMatchAll, Mode=TwoWay}"
                                         Content="Match All" />
                            <RadioButton GroupName="MatchModeGroup"
                                         Style="{StaticResource MaterialDesignTabRadioButton}"
                                         Foreground="{DynamicResource TertiaryBrush}"
                                         BorderBrush="{DynamicResource TertiaryBrush}"
                                         IsChecked="{Binding IsMatchAny, Mode=TwoWay}"
                                         Content="Match Any" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Margin="0,8,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="Clear All"
                                    Command="{Binding ClearAllCommand}"
                                    Style="{StaticResource InteractionButton}"
                                    Margin="0,0,8,0"
                                    MinWidth="92" />
                            <Button Content="Search"
                                    Command="{Binding SearchCommand}"
                                    Style="{StaticResource InteractionButton}"
                                    Margin="0,0,8,0"
                                    MinWidth="92" />
                            <Button Content="Close"
                                    Style="{StaticResource InteractionButton}"
                                    MinWidth="92"
                                    Click="CloseButton_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
