<Window x:Class="Listen2MeRefined.WPF.Views.NewSongWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        xmlns:windows="clr-namespace:Listen2MeRefined.Application.ViewModels.Windows;assembly=Listen2MeRefined.Application"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance windows:NewSongWindowViewModel}"
        Style="{DynamicResource BasicWindow}"
        Topmost="{Binding IsTopmost}"
        ResizeMode="NoResize"
        FontSize="15"
        Title="Now Playing"
        Height="180"
        Width="500">

    <Border BorderBrush="{DynamicResource TertiaryBrush}"
            Background="{DynamicResource HoloBackground}"
            BorderThickness="2"
            CornerRadius="0,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="10,5"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource DarkBorderBackgroundBrush}">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="22"
                            Height="22"
                            Background="{DynamicResource TertiaryBrush}"
                            CornerRadius="11"
                            VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="MusicNote"
                                                 Width="13"
                                                 Height="13"
                                                 Foreground="{DynamicResource SecondaryBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1"
                                Margin="8,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Style="{DynamicResource NewSongHeaderText}" Text="Now Playing" />
                        <Ellipse Width="5"
                                 Height="5"
                                 Fill="{DynamicResource TertiaryBrush}"
                                 Margin="8,0,8,0"
                                 VerticalAlignment="Center" />
                        <TextBlock Style="{DynamicResource NewSongHeaderText}"
                                   Foreground="{DynamicResource SecondaryDarkBrush}"
                                   Text="{Binding Song.Length, StringFormat={}{0:mm\\:ss}, FallbackValue=00:00}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{DynamicResource DarkBorderContainer}"
                    Margin="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="4" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Style="{DynamicResource NewSongTrackTitleText}"
                               Text="{Binding Song.Title, FallbackValue=Title}" />
                    <TextBlock Grid.Row="2"
                               Style="{DynamicResource NewSongTrackArtistText}"
                               Text="{Binding Song.Artist, FallbackValue=Artist}" />

                    <components:MetaBadgeRow Grid.Row="4"
                                             BpmText="{Binding Song.BPM, StringFormat={}{0} BPM, FallbackValue=0 BPM}"
                                             BitrateText="{Binding Song.Bitrate, StringFormat={}{0} Kbps, FallbackValue=1411 Kbps}"
                                             GenreText="{Binding Song.Genre, FallbackValue=Genre}"
                                             ShowLength="False" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>

