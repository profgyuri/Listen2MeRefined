<Window x:Class="Listen2MeRefined.WPF.Views.AddDroppedSongFolderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        Style="{DynamicResource BasicWindow}"
        Title="Add music folder"
        Height="280"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border BorderBrush="{StaticResource TertiaryBrush}"
            Background="{StaticResource HoloBackground}"
            BorderThickness="2"
            CornerRadius="0,0,10,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0"
                                 CenterText="Add music folder"
                                 ShowSettingsButton="False"
                                 ShowTaskStatus="False"
                                 ShowMinimizeButton="False"
                                 ShowMaximizeButton="False"
                                 ShowCloseButton="True" />

            <Border Grid.Row="2"
                    Margin="10 0"
                    Background="#272727"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Foreground="#D7D7D7"
                               TextWrapping="Wrap"
                               FontSize="14"
                               Text="This song's folder is not in your music folder list. Add it now?" />
                    <TextBlock Grid.Row="1"
                               x:Name="FolderPathText"
                               VerticalAlignment="Center"
                               Margin="0,10,0,0"
                               Foreground="#A8A8A8"
                               TextWrapping="Wrap"
                               FontFamily="Consolas" />
                    <CheckBox Grid.Row="2" 
                              x:Name="DontAskAgainCheckBox"
                              Margin="0,10,0,5"
                              Foreground="#D7D7D7"
                              Content="Don't ask again for this folder" />
                </Grid>
            </Border>

            <components:WindowFooterBar Grid.Row="4"
                                        Margin="10 0 10 10"
                                        PrimaryButtonText="Yes, add folder"
                                        SecondaryButtonText="No"
                                        ShowSecondaryButton="True"
                                        InfoText="You can update music folders later in Settings."
                                        PrimaryClick="FooterBar_OnPrimaryClick"
                                        SecondaryClick="FooterBar_OnSecondaryClick" />
        </Grid>
    </Border>
</Window>
