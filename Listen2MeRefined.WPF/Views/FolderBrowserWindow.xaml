<Window x:Class="Listen2MeRefined.WPF.FolderBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        xmlns:windows="clr-namespace:Listen2MeRefined.Application.ViewModels.Windows;assembly=Listen2MeRefined.Application"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance windows:FolderBrowserViewModel}"
        Style="{DynamicResource BasicWindow}"
        FontFamily="{Binding FontFamilyName, Converter={StaticResource StringToFontFamily}}"
        Title="Folder Browser"
        Height="520"
        Width="860"
        MinHeight="470"
        MinWidth="760">

    <Window.InputBindings>
        <KeyBinding Key="V" Modifiers="Ctrl" Command="{Binding NavigateToClipboardPathCommand}" />
        <KeyBinding Key="Escape" Command="{x:Static SystemCommands.CloseWindowCommand}" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static SystemCommands.CloseWindowCommand}" Executed="CancelButton_Click" />
    </Window.CommandBindings>

    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>

    <Border BorderThickness="2"
            BorderBrush="{DynamicResource TertiaryBrush}"
            Background="{DynamicResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0"
                                 CenterText="Folder Browser"
                                 ShowSettingsButton="False"
                                 ShowMinimizeButton="False"
                                 ShowMaximizeButton="False"
                                 ShowCloseButton="True" />

            <Border Grid.Row="1"
                    Style="{DynamicResource BorderContainer}"
                    Margin="10,10,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{DynamicResource DarkBorderContainer}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{DynamicResource FolderBrowserSectionTitleText}" Text="Pinned" />
                                <ListView Height="180"
                                          ItemsSource="{Binding PinnedFolders}"
                                          SelectedItem="{Binding SelectedPinnedFolder}"
                                          Style="{DynamicResource FolderBrowserListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource SecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding SelectPinnedFolderCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>

                                <TextBlock Style="{DynamicResource FolderBrowserSectionTitleText}" Margin="0,10,0,6" Text="Drives" />
                                <ListView Height="130"
                                          ItemsSource="{Binding Drives}"
                                          SelectedItem="{Binding SelectedDrive}"
                                          Style="{DynamicResource FolderBrowserListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{DynamicResource SecondaryBrush}" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding SelectDriveCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{DynamicResource DarkBorderContainer}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource SecondaryBrush}" FontSize="14" FontWeight="SemiBold" Text="Navigate To Folder" />
                                    <TextBlock Foreground="{DynamicResource SecondaryDarkBrush}" FontSize="11" Text="Right/Enter opens, Left goes parent, Ctrl+L focuses path." />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryDarkBrush}"
                                           FontSize="11"
                                           Text="{Binding Folders.Count, StringFormat={}{0} items}" />
                            </Grid>

                            <TextBox x:Name="FilterTextBox"
                                     Grid.Row="2"
                                     materialDesign:HintAssist.Hint="Filter current view..."
                                     materialDesign:HintAssist.Foreground="{DynamicResource SecondaryDarkBrush}"
                                     Foreground="{DynamicResource SecondaryBrush}"
                                     Background="{DynamicResource PrimaryLightBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Padding="10,0"
                                     Height="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Border Grid.Row="4"
                                    Style="{DynamicResource BorderContainer}"
                                    Padding="5">
                                <ListView x:Name="FolderList"
                                          ItemsSource="{Binding Folders}"
                                          SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                                          Style="{DynamicResource FolderBrowserListView}">
                                    <ListView.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding NavigateIntoSelectedCommand}" />
                                        <KeyBinding Key="Right" Command="{Binding NavigateIntoSelectedCommand}" />
                                        <KeyBinding Key="Left" Command="{Binding NavigateParentCommand}" />
                                        <KeyBinding Key="Back" Command="{Binding NavigateParentCommand}" />
                                    </ListView.InputBindings>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Kind="FolderOutline"
                                                                         Width="14"
                                                                         Height="14"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"
                                                                         Foreground="{DynamicResource SecondaryDarkBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           Foreground="{DynamicResource SecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding NavigateIntoSelectedCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>
                            </Border>

                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Style="{DynamicResource BorderContainer}"
                                        Padding="10,0">
                                    <TextBlock x:Name="PathTextBlock"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               Background="Transparent"
                                               Height="36"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullPath}"
                                               Text="{Binding FullPath}" />
                                </Border>
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Content="Pin Current"
                                        Command="{Binding TogglePinCommand}"
                                        Style="{DynamicResource FolderBrowserActionButton}"
                                        MinWidth="108" />
                            </Grid>

                            <TextBlock Grid.Row="7"
                                       Margin="4,6,0,0"
                                       Foreground="{DynamicResource ValidationErrorBrush}"
                                       FontSize="11"
                                       Text="{Binding ValidationMessage}"
                                       Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <components:WindowFooterBar Grid.Row="2"
                                        Margin="10,10,10,10"
                                        InfoText="Enter/Right to open. Left to go back. Ctrl+V jumps to clipboard path. Select adds folder to library."
                                        PrimaryButtonText="Select"
                                        PrimaryButtonMinWidth="110"
                                        ShowSecondaryButton="True"
                                        SecondaryButtonText="Cancel"
                                        SecondaryButtonMinWidth="110"
                                        PrimaryClick="SelectButton_Click"
                                        SecondaryClick="CancelButton_Click" />
        </Grid>
    </Border>
</Window>

