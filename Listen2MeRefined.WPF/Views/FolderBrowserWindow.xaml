<Window x:Class="Listen2MeRefined.WPF.FolderBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Listen2MeRefined.Infrastructure.Mvvm;assembly=Listen2MeRefined.Infrastructure"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:FolderBrowserViewModel}"
        Style="{StaticResource BasicWindow}"
        Title="Folder Browser"
        Height="440"
        Width="640"
        MinHeight="400"
        MinWidth="580">

    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TitleActionButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="BtnBorder" Property="Background" Value="#353535" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#242424" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseTitleActionButton" TargetType="Button" BasedOn="{StaticResource TitleActionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#970000" />
                    <Setter Property="BorderBrush" Value="#970000" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6F0000" />
                    <Setter Property="BorderBrush" Value="#6F0000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource InteractionButton}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryBrush}" />
            <Setter Property="BorderBrush" Value="#4A4A4A" />
            <Setter Property="Background" Value="#303030" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource TertiaryLightMidBrush}" />
                                <Setter TargetName="BtnBorder" Property="Background" Value="#383838" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#262626" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FolderList" TargetType="ListView" BasedOn="{StaticResource VirtualizedListView}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Background" Value="#252525" />
                        <Setter Property="BorderBrush" Value="#353535" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="0"
                                            Padding="8,5">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#2C2C2C" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource TertiaryBrush}" />
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#323232" />
                                            <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1" />
                                            <Setter TargetName="ItemBorder" Property="CornerRadius" Value="4" />
                                            <Setter Property="Margin" Value="0,1,0,1" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderThickness="2"
            BorderBrush="{StaticResource TertiaryBrush}"
            Background="{StaticResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="10,4"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,0,0,1"
                    Background="#232323">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            WindowChrome.IsHitTestVisibleInChrome="False"
                            CornerRadius="9"
                            BorderThickness="1"
                            BorderBrush="#3F3F3F"
                            Background="#2B2B2B"
                            Height="30"
                            Padding="8,4"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="pack://application:,,,/Resources/Listen2Me.ico"
                                   Width="16"
                                   Height="16"
                                   SnapsToDevicePixels="True"
                                   Margin="0,0,7,0" />
                            <TextBlock Text="Listen2Me Refined"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="0"
                            Grid.ColumnSpan="3"
                            WindowChrome.IsHitTestVisibleInChrome="False"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Height="30"
                            Padding="10,4"
                            CornerRadius="10"
                            BorderThickness="1"
                            BorderBrush="#3D3D3D"
                            Background="#292929">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="6"
                                     Height="6"
                                     Fill="{StaticResource TertiaryBrush}"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="Folder Browser"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource CloseTitleActionButton}"
                                Content="{materialDesign:PackIcon Kind=Close,Size=15}"
                                Click="CancelButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="1"
                    Margin="10,10,10,0"
                    Background="#272727"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#232323"
                            BorderBrush="#393939"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="24"
                                    Height="24"
                                    Background="{StaticResource TertiaryBrush}"
                                    CornerRadius="12"
                                    VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="FolderSearchOutline"
                                                         Width="14"
                                                         Height="14"
                                                         Foreground="#1F1F1F"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Foreground="{StaticResource SecondaryBrush}" FontSize="14" FontWeight="SemiBold" Text="Select Music Folder" />
                                <TextBlock Foreground="#A8A8A8" FontSize="11" Text="Double-click to open directories, Enter to navigate." />
                            </StackPanel>

                            <TextBlock Grid.Column="2"
                                       Foreground="#A8A8A8"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Text="{Binding Folders.Count, StringFormat={}{0} items}" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="#232323"
                            BorderBrush="#393939"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="4">
                        <ListView x:Name="FolderList"
                                  ItemsSource="{Binding Folders}"
                                  SelectedItem="{Binding SelectedFolder}"
                                  Style="{StaticResource FolderList}">
                            <ListView.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding ChangeDirectoryCommand}" />
                            </ListView.InputBindings>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <materialDesign:PackIcon Kind="FolderOutline"
                                                                 Width="14"
                                                                 Height="14"
                                                                 Margin="0,0,8,0"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="#AAAAAA" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding}"
                                                   Foreground="{StaticResource SecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseDoubleClick">
                                    <i:InvokeCommandAction Command="{Binding ChangeDirectoryCommand}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </ListView>
                    </Border>

                    <Border Grid.Row="4"
                            Background="#232323"
                            BorderBrush="#3D3D3D"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,0">
                        <TextBox materialDesign:HintAssist.Hint="Full path:"
                                 materialDesign:HintAssist.Foreground="#9A9A9A"
                                 Foreground="{StaticResource SecondaryBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Height="36"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding FullPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="10,10,10,10"
                    Background="#232323"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Foreground="#A8A8A8"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Text="Select confirms and saves the selection." />

                    <Button Grid.Column="1"
                            Content="Select"
                            Command="{Binding HandleSelectedPathCommand}"
                            Style="{StaticResource ActionButton}"
                            MinWidth="110">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <i:CallMethodAction MethodName="Close"
                                                    TargetObject="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>

                    <Button x:Name="CancelButton"
                            Grid.Column="2"
                            Content="Cancel"
                            Style="{StaticResource ActionButton}"
                            MinWidth="110"
                            Margin="8,0,0,0"
                            Click="CancelButton_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
