<Window x:Class="Listen2MeRefined.WPF.FolderBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Listen2MeRefined.Infrastructure.Mvvm;assembly=Listen2MeRefined.Infrastructure"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:FolderBrowserViewModel}"
        Style="{StaticResource BasicWindow}"
        Title="Folder Browser"
        Height="520"
        Width="860"
        MinHeight="470"
        MinWidth="760"
        PreviewKeyDown="Window_PreviewKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome x:Name="WindowChrome" CaptionHeight="40" />
    </WindowChrome.WindowChrome>

    <Border BorderThickness="2"
            BorderBrush="{StaticResource TertiaryBrush}"
            Background="{StaticResource PrimaryBrush}"
            CornerRadius="0,0,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="{Binding ElementName=WindowChrome, Path=CaptionHeight, FallbackValue=40}" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <components:TitleBar Grid.Row="0"
                                 CenterText="Folder Browser"
                                 ShowSettingsButton="False"
                                 ShowMinimizeButton="False"
                                 ShowMaximizeButton="False"
                                 ShowCloseButton="True" />

            <Border Grid.Row="1"
                    Margin="10,10,10,0"
                    Background="#272727"
                    BorderBrush="#3A3A3A"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#232323"
                            BorderBrush="#393939"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource FolderBrowserSectionTitleText}" Text="Pinned" />
                                <ListView Height="180"
                                          ItemsSource="{Binding PinnedFolders}"
                                          SelectedItem="{Binding SelectedPinnedFolder}"
                                          Style="{StaticResource FolderBrowserListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{StaticResource SecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding SelectPinnedFolderCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>

                                <TextBlock Style="{StaticResource FolderBrowserSectionTitleText}" Margin="0,10,0,6" Text="Drives" />
                                <ListView Height="130"
                                          ItemsSource="{Binding Drives}"
                                          SelectedItem="{Binding SelectedDrive}"
                                          Style="{StaticResource FolderBrowserListView}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource SecondaryBrush}" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding SelectDriveCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2"
                            Background="#232323"
                            BorderBrush="#393939"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource SecondaryBrush}" FontSize="14" FontWeight="SemiBold" Text="Navigate To Folder" />
                                    <TextBlock Foreground="#A8A8A8" FontSize="11" Text="Right/Enter opens, Left goes parent, Ctrl+L focuses path." />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="#A8A8A8"
                                           FontSize="11"
                                           Text="{Binding Folders.Count, StringFormat={}{0} items}" />
                            </Grid>

                            <TextBox x:Name="FilterTextBox"
                                     Grid.Row="2"
                                     materialDesign:HintAssist.Hint="Filter current view..."
                                     materialDesign:HintAssist.Foreground="#9A9A9A"
                                     Foreground="{StaticResource SecondaryBrush}"
                                     Background="#2A2A2A"
                                     BorderBrush="#3D3D3D"
                                     BorderThickness="1"
                                     Padding="10,0"
                                     Height="34"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <Border Grid.Row="4"
                                    Background="#262626"
                                    BorderBrush="#3D3D3D"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="4">
                                <ListView x:Name="FolderList"
                                          ItemsSource="{Binding Folders}"
                                          SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                                          Style="{StaticResource FolderBrowserListView}">
                                    <ListView.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding NavigateIntoSelectedCommand}" />
                                        <KeyBinding Key="Right" Command="{Binding NavigateIntoSelectedCommand}" />
                                        <KeyBinding Key="Left" Command="{Binding NavigateParentCommand}" />
                                        <KeyBinding Key="Back" Command="{Binding NavigateParentCommand}" />
                                    </ListView.InputBindings>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <materialDesign:PackIcon Kind="FolderOutline"
                                                                         Width="14"
                                                                         Height="14"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"
                                                                         Foreground="#AAAAAA" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           Foreground="{StaticResource SecondaryBrush}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding NavigateIntoSelectedCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ListView>
                            </Border>

                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="#2A2A2A"
                                        BorderBrush="#3D3D3D"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,0">
                                    <TextBox x:Name="PathTextBox"
                                             materialDesign:HintAssist.Hint="Full path"
                                             materialDesign:HintAssist.Foreground="#9A9A9A"
                                             Foreground="{StaticResource SecondaryBrush}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Height="36"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding FullPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding GoToPathCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                </Border>
                                <Button Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Content="Go"
                                        Command="{Binding GoToPathCommand}"
                                        Style="{StaticResource FolderBrowserActionButton}"
                                        MinWidth="78" />
                                <Button Grid.Column="2"
                                        Margin="8,0,0,0"
                                        Content="Pin Current"
                                        Command="{Binding TogglePinCommand}"
                                        Style="{StaticResource FolderBrowserActionButton}"
                                        MinWidth="108" />
                            </Grid>

                            <TextBlock Grid.Row="7"
                                       Margin="4,6,0,0"
                                       Foreground="#E2A4A4"
                                       FontSize="11"
                                       Text="{Binding ValidationMessage}"
                                       Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <components:WindowFooterBar Grid.Row="2"
                                        Margin="10,10,10,10"
                                        InfoText="Enter/Right to open folder. Left to go back. Select adds folder to library."
                                        PrimaryButtonText="Select"
                                        PrimaryButtonMinWidth="110"
                                        ShowSecondaryButton="True"
                                        SecondaryButtonText="Cancel"
                                        SecondaryButtonMinWidth="110"
                                        PrimaryClick="SelectButton_Click"
                                        SecondaryClick="CancelButton_Click" />
        </Grid>
    </Border>
</Window>

