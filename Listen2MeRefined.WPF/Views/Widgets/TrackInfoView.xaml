<UserControl x:Class="Listen2MeRefined.WPF.Views.Widgets.TrackInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance windows:MainWindowViewModel}"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:windows="clr-namespace:Listen2MeRefined.Application.ViewModels.Windows;assembly=Listen2MeRefined.Application">
    <Border Style="{DynamicResource BorderContainer}"
            Margin="0,0,10,0">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="*" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{DynamicResource DarkBorderContainer}">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <materialDesign:PackIcon Kind="Equalizer"
                                                 Width="14"
                                                 Height="14"
                                                 Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource TertiaryBrush}" />
                        <TextBlock Style="{DynamicResource TrackInfoInfoBadgeText}" Text="NOW PLAYING" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border DockPanel.Dock="Right"
                            Style="{DynamicResource StatusBorderContainer}"
                            HorizontalAlignment="Right"
                            Padding="7,2,7,2">
                        <TextBlock FontSize="10"
                                   Foreground="{DynamicResource TertiaryLightBrush}"
                                   Text="{Binding PlayerState}" />
                    </Border>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Style="{DynamicResource TrackInfoMetricCardBorder}"
                    Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryBrush}"
                               Text="{Binding Song.Title, FallbackValue=Title}"
                               TextTrimming="CharacterEllipsis" />

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <materialDesign:PackIcon Kind="AccountMusic"
                                                 VerticalAlignment="Center"
                                                 Width="15"
                                                 Height="15"
                                                 Margin="0,0,6,0"
                                                 Foreground="{DynamicResource SecondaryDarkBrush}" />
                        <TextBlock FontSize="17"
                                   Foreground="{DynamicResource SecondaryDarkBrush}"
                                   Text="{Binding Song.Artist, FallbackValue=Artist}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="4" Columns="3">
                <Border Style="{DynamicResource TrackInfoMetricCardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Metronome"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,5,0"
                                                     Foreground="{DynamicResource TertiaryBrush}" />
                            <TextBlock Style="{DynamicResource TrackInfoMetricLabelText}" Text="TEMPO" />
                        </StackPanel>
                        <TextBlock Style="{DynamicResource TrackInfoMetricValueText}"
                                   Margin="0,4,0,0"
                                   Text="{Binding Song.BPM, StringFormat={}{0} BPM, FallbackValue=0 BPM}" />
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource TrackInfoMetricCardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShapeOutline"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,5,0"
                                                     Foreground="{DynamicResource TertiaryBrush}" />
                            <TextBlock Style="{DynamicResource TrackInfoMetricLabelText}" Text="GENRE" />
                        </StackPanel>
                        <TextBlock Style="{DynamicResource TrackInfoMetricValueText}"
                                   Margin="0,4,0,0"
                                   Text="{Binding Song.Genre, FallbackValue=Genre}" />
                    </StackPanel>
                </Border>

                <Border Style="{DynamicResource TrackInfoMetricCardBorder}" Margin="0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="SignalCellular3"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,5,0"
                                                     Foreground="{DynamicResource TertiaryBrush}" />
                            <TextBlock Style="{DynamicResource TrackInfoMetricLabelText}" Text="BITRATE" />
                        </StackPanel>
                        <TextBlock Style="{DynamicResource TrackInfoMetricValueText}"
                                   Margin="0,4,0,0"
                                   Text="{Binding Song.Bitrate, StringFormat={}{0} Kbps, FallbackValue=1411 Kbps}" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>

