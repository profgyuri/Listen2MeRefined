<UserControl x:Class="Listen2MeRefined.WPF.Views.Widgets.TrackInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance widgets:TrackInfoViewModel}"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:resources="clr-namespace:Listen2MeRefined.WPF"
             xmlns:utils="clr-namespace:Listen2MeRefined.WPF.Utils"
             xmlns:widgets="clr-namespace:Listen2MeRefined.Application.ViewModels.Widgets;assembly=Listen2MeRefined.Application">
    <Grid VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="4" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="6" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title + Player State -->
        <DockPanel Grid.Row="0" ClipToBounds="True">
            <Border DockPanel.Dock="Right"
                    Style="{DynamicResource StatusBorderContainer}"
                    Padding="7,2"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center">
                <TextBlock FontSize="10"
                           Foreground="{DynamicResource TertiaryLightBrush}"
                           FontFamily="{Binding FontFamilyName}"
                           Text="{Binding PlayerState}" />
            </Border>
            <resources:StoryboardTextBlock
                FontSize="20"
                FontWeight="Bold"
                Foreground="{DynamicResource SecondaryBrush}"
                FontFamily="{Binding FontFamilyName}"
                Text="{Binding Song.Title, FallbackValue=Title}"
                TextTrimming="None"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                ClipToBounds="True"
                utils:FlowingTextBehavior.IsEnabled="True" />
        </DockPanel>

        <!-- Artist -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" ClipToBounds="True">
            <materialDesign:PackIcon Kind="AccountMusic"
                                     VerticalAlignment="Center"
                                     Width="14"
                                     Height="14"
                                     Margin="0,0,6,0"
                                     Foreground="{DynamicResource SecondaryDarkBrush}" />
            <resources:StoryboardTextBlock
                FontSize="14"
                Foreground="{DynamicResource SecondaryDarkBrush}"
                FontFamily="{Binding FontFamilyName}"
                Text="{Binding Song.Artist, FallbackValue=Artist}"
                TextTrimming="None"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                ClipToBounds="True"
                utils:FlowingTextBehavior.IsEnabled="True" />
        </StackPanel>

        <!-- Compact metadata line -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <TextBlock Style="{DynamicResource TrackInfoCompactMetricText}"
                       FontFamily="{Binding FontFamilyName}"
                       Text="{Binding Song.BPM, StringFormat={}{0} BPM, FallbackValue=0 BPM}" />
            <TextBlock Style="{DynamicResource TrackInfoCompactSeparatorText}" Text="|" />
            <TextBlock Style="{DynamicResource TrackInfoCompactMetricText}"
                       FontFamily="{Binding FontFamilyName}"
                       Text="{Binding Song.Genre, FallbackValue=Genre}" />
            <TextBlock Style="{DynamicResource TrackInfoCompactSeparatorText}" Text="|" />
            <TextBlock Style="{DynamicResource TrackInfoCompactMetricText}"
                       FontFamily="{Binding FontFamilyName}"
                       Text="{Binding Song.Bitrate, StringFormat={}{0} Kbps, FallbackValue=0 Kbps}" />
        </StackPanel>
    </Grid>
</UserControl>
