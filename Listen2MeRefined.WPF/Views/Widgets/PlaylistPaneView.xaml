<UserControl x:Class="Listen2MeRefined.WPF.Views.Widgets.PlaylistPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             FontFamily="{Binding FontFamilyName, Converter={StaticResource StringToFontFamily}}"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance widgetViewModels:PlaylistPaneViewModel}"
             xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
             xmlns:contextMenus="clr-namespace:Listen2MeRefined.WPF.Views.ContextMenus"
             xmlns:resources="clr-namespace:Listen2MeRefined.WPF"
             xmlns:utils="clr-namespace:Listen2MeRefined.WPF.Utils"
             xmlns:widgetViewModels="clr-namespace:Listen2MeRefined.Application.ViewModels.Widgets;assembly=Listen2MeRefined.Application">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <ContentControl Content="{Binding PlaylistSidebarViewModel}"/>

        <!-- Separator -->
        <Border Grid.Column="1"
                Background="{DynamicResource BorderBrush}"/>

        <!-- Song list area -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: playlist name + Clear -->
            <Grid Margin="12,8,12,8" MinHeight="28">
                <TextBlock Text="{Binding ActivePlaylistName}"
                           Foreground="{DynamicResource SecondaryBrush}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <Button Content="Clear"
                        HorizontalAlignment="Right"
                        ToolTip="Remove selected or clear playlist"
                        Style="{DynamicResource PlaylistPaneHeaderClearPill}"
                        Command="{Binding RemoveSelectedFromActiveTabCommand}"/>
            </Grid>

            <!-- Separator -->
            <Border Grid.Row="1"
                    Background="{DynamicResource BorderBrush}"/>

            <!-- Playlist ListView -->
            <ListView Grid.Row="2"
                      dd:DragDrop.IsDragSource="True"
                      dd:DragDrop.IsDropTarget="True"
                      AllowDrop="True"
                      PreviewDragOver="PlaylistListView_OnPreviewDragOver"
                      PreviewDrop="PlaylistListView_OnPreviewDrop"
                      ItemsSource="{Binding CurrentPlaylistSongs}"
                      Style="{DynamicResource PlaylistListView}"
                      PreviewMouseRightButtonDown="ListViewOnPreviewMouseRightButtonDown"
                      SelectedItem="{Binding SelectedSong, Mode=TwoWay}"
                      SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                      SelectionMode="Extended"
                      utils:SelectionChangedCommandBehavior.AddedItemsCommand="{Binding PlaylistSelectionAddedCommand}"
                      utils:SelectionChangedCommandBehavior.RemovedItemsCommand="{Binding PlaylistSelectionRemovedCommand}"
                      utils:SelectionChangedCommandBehavior.ScrollSelectedItemIntoView="True">

                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="MouseDoubleClick">
                        <i:InvokeCommandAction Command="{Binding PlaySelectedFromActiveTabCommand}"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>

                <ListView.InputBindings>
                    <KeyBinding Modifiers="Ctrl" Key="Delete"
                                Command="{Binding RemoveSelectedFromActiveTabCommand}"/>
                    <KeyBinding Modifiers="Ctrl+Shift" Key="Delete"
                                Command="{Binding RemoveSelectedFromActiveTabCommand}"/>
                </ListView.InputBindings>

                <ListView.ContextMenu>
                    <contextMenus:SongContextMenu DataContext="{Binding PlacementTarget.DataContext.SongContextMenuViewModel, RelativeSource={RelativeSource Self}}" />
                </ListView.ContextMenu>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid MinWidth="300" ClipToBounds="True">

                            <!-- Detailed view -->
                            <Grid x:Name="DetailedViewRoot">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="3"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <resources:StoryboardTextBlock
                                    Text="{Binding Display, FallbackValue=Track Title}"
                                    Foreground="{DynamicResource SecondaryBrush}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    TextTrimming="None"
                                    HorizontalAlignment="Left"
                                    ClipToBounds="True"
                                    utils:FlowingTextBehavior.IsEnabled="True"/>

                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <TextBlock Style="{DynamicResource PlaylistDetailMetricText}"
                                               Text="{Binding Length, StringFormat={}{0:mm\\:ss}, FallbackValue=0:00}" />
                                    <TextBlock Style="{DynamicResource PlaylistDetailSeparatorText}" Text="|" />
                                    <TextBlock Style="{DynamicResource PlaylistDetailMetricText}"
                                               Text="{Binding Genre, FallbackValue=Genre}" />
                                    <TextBlock Style="{DynamicResource PlaylistDetailSeparatorText}" Text="|" />
                                    <TextBlock Style="{DynamicResource PlaylistDetailMetricText}"
                                               Text="{Binding BPM, StringFormat={}{0} BPM, FallbackValue=0 BPM}" />
                                    <TextBlock Style="{DynamicResource PlaylistDetailSeparatorText}" Text="|" />
                                    <TextBlock Style="{DynamicResource PlaylistDetailMetricText}"
                                               Text="{Binding Bitrate, StringFormat={}{0} Kbps, FallbackValue=0 Kbps}" />
                                </StackPanel>
                            </Grid>

                            <!-- Compact view -->
                            <Grid x:Name="CompactViewRoot" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <resources:StoryboardTextBlock
                                    Text="{Binding Display, FallbackValue=Track Title}"
                                    Foreground="{DynamicResource SecondaryBrush}"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    TextTrimming="None"
                                    HorizontalAlignment="Left"
                                    ClipToBounds="True"
                                    utils:FlowingTextBehavior.IsEnabled="True"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Length, StringFormat={}{0:mm\\:ss}, FallbackValue=0:00}"
                                           Foreground="{DynamicResource SecondaryDarkBrush}"
                                           FontSize="11"
                                           Opacity="0.7"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                            </Grid>
                        </Grid>

                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsCompactPlaylistView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                         Value="True">
                                <Setter TargetName="DetailedViewRoot" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="CompactViewRoot" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state overlay -->
            <components:EmptyStateOverlay Grid.Row="2"
                                          IconKind="MusicNote"
                                          PrimaryText="Drop tracks here"
                                          SecondaryText="or double-click from the library">
                <components:EmptyStateOverlay.Style>
                    <Style TargetType="components:EmptyStateOverlay">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentPlaylistSongs.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </components:EmptyStateOverlay.Style>
            </components:EmptyStateOverlay>
        </Grid>
    </Grid>
</UserControl>
