<UserControl x:Class="Listen2MeRefined.WPF.Views.Widgets.MainHomeContentToggleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:widgets="clr-namespace:Listen2MeRefined.Application.ViewModels.Widgets;assembly=Listen2MeRefined.Application"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance widgets:MainHomeContentToggleViewModel}">
    <StackPanel Style="{DynamicResource MainHomeContentToggleContainer}">
        <Button Command="{Binding ShowPlaylistCommand}"
                Style="{DynamicResource MainHomeContentPlaylistToggleButton}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="PlaylistMusic"
                                         Width="14"
                                         Height="14"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                <TextBlock Text="Playlist"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Button>
        <Button Command="{Binding ShowSearchResultsCommand}"
                Style="{DynamicResource MainHomeContentSearchResultsToggleButton}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Magnify"
                                         Width="14"
                                         Height="14"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                <TextBlock Text="Search Results"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Button>
    </StackPanel>
</UserControl>
