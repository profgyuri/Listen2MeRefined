<UserControl x:Class="Listen2MeRefined.WPF.Views.Widgets.SearchResultsPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance widgetViewModels:SearchResultsPaneViewModel}"
             FontFamily="{Binding FontFamilyName, Converter={StaticResource StringToFontFamily}}"
             xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
             xmlns:contextMenus="clr-namespace:Listen2MeRefined.WPF.Views.ContextMenus"
             xmlns:utils="clr-namespace:Listen2MeRefined.WPF.Utils"
             xmlns:widgetViewModels="clr-namespace:Listen2MeRefined.Application.ViewModels.Widgets;assembly=Listen2MeRefined.Application">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition x:Name="ListRow" Height="*" />
        </Grid.RowDefinitions>

        <components:SectionHeader Grid.Row="0"
                                  Title="Search Results"
                                  IconKind="MusicNote"
                                  ShowActionButton="True"
                                  ActionToolTip="Send selected (or all) to playlist"
                                  ActionButtonText="To Playlist"
                                  ActionIconKind="ArrowRight"
                                  ActionCommand="{Binding SendSelectedToPlaylistCommand}" />

        <ListView Grid.Row="2"
                  Height="{Binding ElementName=ListRow, Path=Height}"
                  Foreground="{DynamicResource SecondaryBrush}"
                  dd:DragDrop.IsDragSource="True"
                  dd:DragDrop.IsDropTarget="True"
                  dd:DragDrop.UseDefaultDragAdorner="True"
                  dd:DragDrop.DefaultDragAdornerOpacity="0.85"
                  dd:DragDrop.DragAdornerTemplate="{StaticResource DragDropDragAdornerTemplate}"
                  PreviewMouseRightButtonDown="ListViewOnPreviewMouseRightButtonDown"
                  ItemsSource="{Binding SearchResults}"
                  SelectionMode="Extended"
                  ItemContainerStyle="{DynamicResource ContentListItemStyle}"
                  Style="{DynamicResource ContentListViewStyle}"
                  utils:SelectionChangedCommandBehavior.AddedItemsCommand="{Binding SearchResultsSelectionAddedCommand}"
                  utils:SelectionChangedCommandBehavior.RemovedItemsCommand="{Binding SearchResultsSelectionRemovedCommand}">
            <ListView.InputBindings>
                <KeyBinding Modifiers="Ctrl" Key="Right" Command="{Binding SendSelectedToPlaylistCommand}"/>
                <KeyBinding Key="Return" Command="{Binding SendSelectedToPlaylistCommand}"/>
            </ListView.InputBindings>
            <ListView.ContextMenu>
                <contextMenus:SongContextMenu DataContext="{Binding PlacementTarget.DataContext.SongContextMenuViewModel, RelativeSource={RelativeSource Self}}" />
            </ListView.ContextMenu>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Row 0: Display text + info toggle on right -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding Display}"
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryBrush}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />

                            <ToggleButton x:Name="RowExpandToggle"
                                          Grid.Column="1"
                                          Style="{DynamicResource SearchResultsInfoToggleStyle}"
                                          ToolTip="Show details"
                                          Margin="8,0,0,0">
                                <Grid>
                                    <materialDesign:PackIcon x:Name="RowInfoIconDefault"
                                                             Kind="InformationOutline"
                                                             Width="14"
                                                             Height="14"
                                                             Foreground="{DynamicResource SecondaryDarkBrush}" />
                                    <materialDesign:PackIcon x:Name="RowInfoIconActive"
                                                             Kind="Information"
                                                             Width="14"
                                                             Height="14"
                                                             Foreground="{DynamicResource TertiaryBrush}"
                                                             Visibility="Collapsed" />
                                </Grid>
                            </ToggleButton>
                        </Grid>

                        <!-- Row 1: Compact metadata line -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <TextBlock Style="{DynamicResource TrackInfoCompactMetricText}"
                                       Text="{Binding Genre, FallbackValue=Genre}" />
                            <TextBlock Style="{DynamicResource TrackInfoCompactSeparatorText}" Text="|" />
                            <TextBlock Style="{DynamicResource TrackInfoCompactMetricText}"
                                       Text="{Binding BPM, StringFormat={}{0} BPM, FallbackValue=0 BPM}" />
                            <TextBlock Style="{DynamicResource TrackInfoCompactSeparatorText}" Text="|" />
                            <TextBlock Style="{DynamicResource TrackInfoCompactMetricText}"
                                       Text="{Binding Bitrate, StringFormat={}{0} Kbps, FallbackValue=0 Kbps}" />
                        </StackPanel>

                        <!-- Row 2: Expandable detail (Path) -->
                        <Border Grid.Row="3"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,6,0,2"
                                Visibility="{Binding IsChecked, ElementName=RowExpandToggle, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Artist" Style="{DynamicResource SearchResultsToolbarLabelText}" />
                                    <TextBlock Text="{Binding Artist}" Style="{DynamicResource SearchResultsToolbarValueText}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel Grid.Row="2">
                                    <TextBlock Text="Path" Style="{DynamicResource SearchResultsToolbarLabelText}" />
                                    <TextBlock Text="{Binding Path}" Style="{DynamicResource SearchResultsToolbarValueText}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                    <DataTemplate.Triggers>
                        <Trigger SourceName="RowExpandToggle" Property="IsChecked" Value="True">
                            <Setter TargetName="RowInfoIconDefault" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="RowInfoIconActive" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state overlay -->
        <components:EmptyStateOverlay Grid.Row="2"
                                      IconKind="Magnify"
                                      PrimaryText="No results found">
            <components:EmptyStateOverlay.Style>
                <Style TargetType="components:EmptyStateOverlay">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SearchResults.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </components:EmptyStateOverlay.Style>
        </components:EmptyStateOverlay>
    </Grid>
</UserControl>
