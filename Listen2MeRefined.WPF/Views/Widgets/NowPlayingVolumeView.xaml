<UserControl x:Class="Listen2MeRefined.WPF.Views.Widgets.NowPlayingVolumeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:widgets="clr-namespace:Listen2MeRefined.Application.ViewModels.Widgets;assembly=Listen2MeRefined.Application"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance widgets:NowPlayingVolumeViewModel}">
    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                HorizontalAlignment="Right">
        <Button Style="{DynamicResource NowPlayingVolumeButton}"
                Command="{Binding ToggleMuteCommand}"
                ToolTip="Mute / Unmute">
            <materialDesign:PackIcon Kind="{Binding VolumeIconKind}" Width="14" Height="14" />
        </Button>
        <Slider Width="84"
                Margin="8,0,0,0"
                Minimum="0"
                Maximum="1"
                Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                PreviewMouseWheel="Slider_OnPreviewMouseWheel" />
    </StackPanel>
</UserControl>
