<UserControl x:Class="Listen2MeRefined.WPF.Views.SettingsTabs.SettingsPlaylistsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:settingsTabs="clr-namespace:Listen2MeRefined.Application.ViewModels.SettingsTabs;assembly=Listen2MeRefined.Application"
             xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
             mc:Ignorable="d"
             FontFamily="{Binding FontFamilyName}"
             d:DataContext="{d:DesignInstance settingsTabs:SettingsPlaylistsTabViewModel}"
             d:DesignHeight="300"
             d:DesignWidth="300">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,0,0,0">
            <Border Style="{DynamicResource DarkBorderContainer}">
                <StackPanel>
                    <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="Playlists" />
                    <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="Manage playlist names and search transfer behavior." />
                </StackPanel>
            </Border>

            <Border Style="{DynamicResource DarkBorderContainer}" Margin="0,10,0,0">
                <StackPanel>
                    <components:FormFieldRow Margin="0,0,0,12"
                                             Label="Search to default tab:"
                                             LabelWidth="190">
                        <components:FormFieldRow.FieldContent>
                            <ComboBox Style="{DynamicResource CustomComboBox}"
                                      SelectedItem="{Binding SelectedSearchResultsTransferMode}"
                                      ItemsSource="{Binding SearchResultsTransferModes}" />
                        </components:FormFieldRow.FieldContent>
                    </components:FormFieldRow>

                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ListView Grid.RowSpan="2"
                                  Height="170"
                                  Margin="0,0,10,0"
                                  Style="{DynamicResource VirtualizedListView}"
                                  ItemsSource="{Binding Playlists}"
                                  SelectedItem="{Binding SelectedPlaylist}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Button Grid.Column="1"
                                Style="{DynamicResource SettingsIconActionButton}"
                                Command="{Binding DeleteSelectedPlaylistCommand}"
                                Content="{materialDesign:PackIcon Kind=DeleteOutline, Size=18}"
                                ToolTip="Delete selected playlist" />
                    </Grid>

                    <components:FormFieldRow Margin="0,0,0,10"
                                             Label="Playlist name:"
                                             LabelWidth="190">
                        <components:FormFieldRow.FieldContent>
                            <TextBox Text="{Binding PlaylistNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="{StaticResource SecondaryBrush}" />
                        </components:FormFieldRow.FieldContent>
                    </components:FormFieldRow>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{DynamicResource SettingsActionButton}"
                                MinWidth="110"
                                Content="Create"
                                Command="{Binding CreatePlaylistCommand}" />
                        <Button Style="{DynamicResource SettingsActionButton}"
                                MinWidth="110"
                                Margin="8,0,0,0"
                                Content="Rename"
                                Command="{Binding RenameSelectedPlaylistCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
