<UserControl x:Class="Listen2MeRefined.WPF.Views.SettingsTabs.SettingsAdvancedTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settingsTabs="clr-namespace:Listen2MeRefined.Application.ViewModels.SettingsTabs;assembly=Listen2MeRefined.Application"
             xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
             mc:Ignorable="d"
             FontFamily="{Binding FontFamilyName}"
             d:DataContext="{d:DesignInstance settingsTabs:SettingsAdvancedTabViewModel}"
             d:DesignHeight="300"
             d:DesignWidth="300">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,0,0,0">
            <components:SectionHeader IconKind="AlertCircleOutline"
                                      Title="Advanced"
                                      ShowSubtitle="True"
                                      Subtitle="Danger zone. Clearing metadata removes songs, playlists, and folder registrations." />

            <Border Margin="0,16,0,0"
                    Background="{DynamicResource SurfaceElevatedBrush}"
                    BorderBrush="{DynamicResource ValidationErrorBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel>
                    <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}"
                               Foreground="{DynamicResource ValidationErrorBrush}"
                               Text="This action cannot be undone. Use it only when you want a full local reset."
                               Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{DynamicResource SettingsSurfaceButton}"
                                MinWidth="150"
                                Content="Clear Metadata"
                                Command="{Binding ClearMetadataCommand}"
                                Visibility="{Binding IsClearMetadataButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Button Style="{DynamicResource SettingsSurfaceButton}"
                                MinWidth="150"
                                Margin="10,0,0,0"
                                Content="{Binding CancelClearMetadataButtonContent}"
                                Visibility="{Binding IsCancelClearMetadataButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding CancelClearMetadataCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
