<UserControl x:Class="Listen2MeRefined.WPF.Views.SettingsTabs.SettingsPlaybackTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:settingsTabs="clr-namespace:Listen2MeRefined.Application.ViewModels.SettingsTabs;assembly=Listen2MeRefined.Application"
             xmlns:components="clr-namespace:Listen2MeRefined.WPF.Views.Components"
             mc:Ignorable="d"
             FontFamily="{Binding FontFamilyName}"
             d:DataContext="{d:DesignInstance settingsTabs:SettingsPlaybackTabViewModel}"
             d:DesignHeight="300"
             d:DesignWidth="300">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,0,0,0">
            <Border Style="{DynamicResource DarkBorderContainer}">
                <StackPanel>
                    <TextBlock Style="{DynamicResource SettingsSectionHeaderText}" Text="Playback" />
                    <TextBlock Style="{DynamicResource SettingsSectionDescriptionText}" Text="Audio output and startup playback defaults." />
                </StackPanel>
            </Border>

            <Border Style="{DynamicResource DarkBorderContainer}" Margin="0,10,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <components:FormFieldRow Grid.ColumnSpan="2"
                                             Label="Audio output:"
                                             LabelWidth="200">
                        <components:FormFieldRow.FieldContent>
                            <ComboBox Style="{DynamicResource CustomComboBox}"
                                      SelectedItem="{Binding SelectedAudioOutputDevice}"
                                      ItemsSource="{Binding AudioOutputDevices}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </components:FormFieldRow.FieldContent>
                    </components:FormFieldRow>

                    <components:LabeledSliderRow Grid.Row="1"
                                                 Grid.ColumnSpan="2"
                                                 Label="Startup volume:"
                                                 LabelWidth="200"
                                                 SliderWidth="240"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 TickFrequency="5"
                                                 IsSnapToTickEnabled="True"
                                                 Value="{Binding StartupVolumePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ValueSuffix="%" />

                    <CheckBox Grid.Row="2"
                              Grid.ColumnSpan="2"
                              Margin="0,12,0,0"
                              IsChecked="{Binding StartMuted}"
                              Content="Start muted" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
