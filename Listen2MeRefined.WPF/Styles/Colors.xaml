<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Charcoal + warm accent palette -->
    <Color x:Key="PrimaryColor">#1F1F1F</Color>
    <Color x:Key="PrimaryLightColor">#2A2A2A</Color>
    <Color x:Key="SecondaryColor">#ECECEC</Color>
    <Color x:Key="TertiaryColor">#FF8A3D</Color>
    <Color x:Key="DarkBorderColor">#3A3A3A</Color>
    <Color x:Key="TertiaryLightColor">#FFB37A</Color>
    <Color x:Key="TertiaryLightMidColor">#D07A42</Color>
    <Color x:Key="TertiaryMidColor">#33FF8A3D</Color>
    <Color x:Key="TertiaryDarkColor">#1FFF8A3D</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{DynamicResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{DynamicResource DarkBorderColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{DynamicResource TertiaryColor}" />
    <SolidColorBrush x:Key="TertiaryLightBrush" Color="{DynamicResource TertiaryLightColor}" />
    <SolidColorBrush x:Key="TertiaryLightMidBrush" Color="{DynamicResource TertiaryLightMidColor}" />
    <SolidColorBrush x:Key="TertiaryMidBrush" Color="{DynamicResource TertiaryMidColor}" />
    <SolidColorBrush x:Key="TertiaryDarkBrush" Color="{DynamicResource TertiaryDarkColor}" />
    <SolidColorBrush x:Key="HoloBackground" Color="{DynamicResource PrimaryColor}" Opacity=".9" />
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="ContainerGradientBackgroundBrush" Color="{DynamicResource PrimaryLightColor}" />
</ResourceDictionary>
