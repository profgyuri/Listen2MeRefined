<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Charcoal + warm accent palette -->
    <Color x:Key="PrimaryColor">#1F1F1F</Color>
    <Color x:Key="PrimaryLightColor">#2A2A2A</Color>
    <Color x:Key="SecondaryColor">#ECECEC</Color>
    <Color x:Key="SecondaryDarkColor">#A8A8A8</Color>
    <Color x:Key="TertiaryColor">#FF8A3D</Color>
    <Color x:Key="BorderColor">#393939</Color>
    <Color x:Key="DefaultBorderBackgroundColor">#282828</Color>
    <Color x:Key="DarkBorderBackgroundColor">#232323</Color>
    <Color x:Key="TertiaryLightColor">#FFB37A</Color>
    <Color x:Key="TertiaryLightMidColor">#D07A42</Color>
    <Color x:Key="TertiaryMidColor">#33FF8A3D</Color>
    <Color x:Key="TertiaryDarkColor">#1FFF8A3D</Color>
    <Color x:Key="ValidationErrorColor">#E26A6A</Color>
    <Color x:Key="SurfaceColor">#1A1A1A</Color>
    <Color x:Key="SurfaceElevatedColor">#242424</Color>
    <Color x:Key="SurfaceRaisedColor">#2E2E2E</Color>
    <Color x:Key="SeparatorColor">#2A2A2A</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{DynamicResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}" />
    <SolidColorBrush x:Key="DefaultBorderBackgroundBrush" Color="{DynamicResource DefaultBorderBackgroundColor}" />
    <SolidColorBrush x:Key="DarkBorderBackgroundBrush" Color="{DynamicResource DarkBorderBackgroundColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}" />
    <SolidColorBrush x:Key="SecondaryDarkBrush" Color="{DynamicResource SecondaryDarkColor}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{DynamicResource TertiaryColor}" />
    <SolidColorBrush x:Key="TertiaryLightBrush" Color="{DynamicResource TertiaryLightColor}" />
    <SolidColorBrush x:Key="TertiaryLightMidBrush" Color="{DynamicResource TertiaryLightMidColor}" />
    <SolidColorBrush x:Key="TertiaryMidBrush" Color="{DynamicResource TertiaryMidColor}" />
    <SolidColorBrush x:Key="TertiaryDarkBrush" Color="{DynamicResource TertiaryDarkColor}" />
    <SolidColorBrush x:Key="HoloBackground" Color="{DynamicResource PrimaryColor}" Opacity=".9" />
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="ContainerGradientBackgroundBrush" Color="{DynamicResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="ValidationErrorBrush" Color="{DynamicResource ValidationErrorColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{DynamicResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{DynamicResource SurfaceElevatedColor}" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{DynamicResource SurfaceRaisedColor}" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="{DynamicResource SeparatorColor}" />
</ResourceDictionary>
