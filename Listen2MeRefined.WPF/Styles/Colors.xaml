<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Charcoal + warm accent palette -->
    <Color x:Key="PrimaryColor">#1F1F1F</Color>
    <Color x:Key="PrimaryLightColor">#2A2A2A</Color>
    <Color x:Key="SecondaryColor">#ECECEC</Color>
    <Color x:Key="TertiaryColor">#FF8A3D</Color>
    <Color x:Key="DarkBorderColor">#3A3A3A</Color>
    <Color x:Key="TertiaryLightColor">#FFB37A</Color>
    <Color x:Key="TertiaryLightMidColor">#D07A42</Color>
    <Color x:Key="TertiaryMidColor">#33FF8A3D</Color>
    <Color x:Key="TertiaryDarkColor">#1FFF8A3D</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorderColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource TertiaryColor}" />
    <SolidColorBrush x:Key="TertiaryLightBrush" Color="{StaticResource TertiaryLightColor}" />
    <SolidColorBrush x:Key="TertiaryLightMidBrush" Color="{StaticResource TertiaryLightMidColor}" />
    <SolidColorBrush x:Key="TertiaryMidBrush" Color="{StaticResource TertiaryMidColor}" />
    <SolidColorBrush x:Key="TertiaryDarkBrush" Color="{StaticResource TertiaryDarkColor}" />
    <SolidColorBrush x:Key="HoloBackground" Color="{StaticResource PrimaryColor}" Opacity=".9" />
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="ContainerGradientBackgroundBrush" Color="{StaticResource PrimaryLightColor}" />
</ResourceDictionary>
