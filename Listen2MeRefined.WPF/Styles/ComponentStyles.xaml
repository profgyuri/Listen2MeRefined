        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            Effect="{TemplateBinding Effect}">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.35" Color="Black" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlaylistContextMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <Grid MinWidth="160">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckHost"
                                    Grid.Column="0"
                                    Width="16"
                                    Height="16"
                                    Margin="6,0,4,0"
                                    VerticalAlignment="Center"
                                    CornerRadius="4"
                                    BorderThickness="0"
                                    Background="{DynamicResource SurfaceBrush}"
                                    Visibility="Collapsed" />

                            <Path x:Name="CheckGlyph"
                                  Grid.Column="0"
                                  Width="8"
                                  Height="6"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Data="M 0 3 L 2.5 5.5 L 8 0"
                                  Stroke="{DynamicResource TertiaryLightBrush}"
                                  StrokeThickness="1.6"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />

                            <ContentPresenter Grid.Column="1"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />

                            <Path x:Name="SubmenuArrow"
                                  Grid.Column="2"
                                  Width="5"
                                  Height="8"
                                  Margin="0,0,8,0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Data="M 0 0 L 5 4 L 0 8"
                                  Stroke="{DynamicResource SecondaryDarkBrush}"
                                  StrokeThickness="1.4"
                                  StrokeEndLineCap="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Visibility="Collapsed" />

                            <Popup x:Name="SubMenuPopup"
                                   Placement="Right"
                                   HorizontalOffset="0"
                                   VerticalOffset="-4"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource SurfaceElevatedBrush}"
                                        Padding="0,4"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.35" Color="Black" />
                                    </Border.Effect>
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCheckable" Value="True">
                            <Setter TargetName="CheckHost" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckHost" Property="Background" Value="{DynamicResource TertiaryDarkBrush}" />
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}" />
                            <Setter TargetName="CheckHost" Property="Opacity" Value="0.4" />
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="0.4" />
                            <Setter TargetName="SubmenuArrow" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

