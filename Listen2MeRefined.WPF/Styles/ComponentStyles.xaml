            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="4,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaylistSidebarItemText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlaylistSidebarItemSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="PlaylistSidebarPinIcon" TargetType="materialDesign:PackIcon">
            <Setter Property="Foreground" Value="{DynamicResource TertiaryBrush}"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="PlaylistSidebarRenameTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TertiaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlaylistSidebarNewButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NewBtnBorder"
                                Background="Transparent"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NewBtnBorder" Property="Background" Value="{DynamicResource SurfaceRaisedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaylistSidebarEmptyHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="Margin" Value="14,4,14,4"/>
        </Style>
        <!--#endregion-->

        <Style x:Key="PlaylistListView" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,4,0,4"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="12,7,12,7"/>
                        <Setter Property="Margin" Value="0,1,0,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="ItemRowBorder"
                                            Background="Transparent"
                                            BorderThickness="1,0,0,0"
                                            BorderBrush="Transparent"
                                            Padding="{TemplateBinding Padding}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemRowBorder" Property="BorderBrush" Value="{DynamicResource TertiaryMidBrush}"/>
                                            <Setter TargetName="ItemRowBorder" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemRowBorder" Property="BorderBrush" Value="{DynamicResource TertiaryBrush}"/>
                                            <Setter TargetName="ItemRowBorder" Property="Background" Value="{DynamicResource TertiaryDarkBrush}"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="True"/>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="ItemRowBorder" Property="BorderBrush" Value="{DynamicResource TertiaryLightBrush}"/>
                                            <Setter TargetName="ItemRowBorder" Property="Background" Value="{DynamicResource TertiaryDarkBrush}"/>
                                        </MultiTrigger>
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource PathEqualsMultiConverter}">
                                                    <Binding Path="Path"/>
                                                    <Binding Path="DataContext.CurrentActiveSongPath"
                                                             RelativeSource="{RelativeSource AncestorType=ListView}"/>
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter TargetName="ItemRowBorder" Property="BorderThickness" Value="4,0,0,0"/>
                                            <Setter TargetName="ItemRowBorder" Property="BorderBrush" Value="{DynamicResource TertiaryBrush}"/>
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel VirtualizingPanel.ScrollUnit="Item"
                                                VirtualizingPanel.VirtualizationMode="Recycling"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--#region Playlist Header New Styles -->
        <Style x:Key="PlaylistPaneHeaderClearPill" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ClearBtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ClearBtnBorder" Property="Background" Value="{DynamicResource TertiaryDarkBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TertiaryLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ClearBtnBorder" Property="Background" Value="{DynamicResource TertiaryMidBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--#endregion-->

        <!--#region Playlist Sort Controls -->
        <Style x:Key="PlaylistPaneHeaderSortDirectionPill" TargetType="Button"
               BasedOn="{StaticResource PlaylistPaneHeaderClearPill}">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="ToolTip" Value="Toggle sort direction"/>
        </Style>

        <Style x:Key="PlaylistSortPropertyComboBox" TargetType="ComboBox"
               BasedOn="{StaticResource MaterialDesignComboBox}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="False"/>
            <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="False"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="Transparent"/>
            <Setter Property="materialDesign:ComboBoxAssist.ShowSelectedItem" Value="True"/>
        </Style>
        <!--#endregion-->

        <!--#region Playlist Detail Inline Metrics -->
        <Style x:Key="PlaylistDetailMetricText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryDarkBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlaylistDetailSeparatorText" TargetType="TextBlock" BasedOn="{StaticResource PlaylistDetailMetricText}">
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        <!--#endregion-->

        <Style TargetType="Separator" x:Key="{x:Static MenuItem.SeparatorStyleKey}">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="10,3"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}" Margin="{TemplateBinding Margin}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    <!--#region Drag-and-Drop Feedback (gong-wpf-dragdrop) -->

    <!-- Drag preview adorner: ghost card shown next to cursor while dragging.
         Note: the insertion line between items is rendered by gong's built-in
         DropTargetInsertionAdorner and is themed via DropTargetAdornerBrush. -->
    <DataTemplate x:Key="DragDropDragAdornerTemplate">
        <Border Background="{DynamicResource SurfaceElevatedBrush}"
                BorderBrush="{DynamicResource TertiaryBrush}"
                BorderThickness="2,0,0,0"
                CornerRadius="4"
                Padding="10,6"
                Opacity="0.9"
                MaxWidth="320">
            <TextBlock Text="{Binding Display}"
                       Foreground="{DynamicResource SecondaryBrush}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </DataTemplate>

    <!--#endregion-->
</ResourceDictionary>
